<Window x:Class="WPEP.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WPEP.App"
        Title="Verdict" Width="1180" Height="760" MinWidth="980" MinHeight="640"
        Background="{DynamicResource Bg}"
        FontFamily="{DynamicResource UiFont}">

  <Window.Resources>
    <local:TokenBrushConverter x:Key="TokenBrush" />
    <local:BoolToVisibilityConverter x:Key="BoolToVis" />
    <local:BoolToVisibilityConverter x:Key="BoolToVisInverted" Invert="True" />
    <local:InverseBoolConverter x:Key="InverseBool" />
    <local:NullToVisibilityConverter x:Key="NullToVis" />

    <!-- ============ VERDICT ============ -->
    <DataTemplate DataType="{x:Type local:VerdictViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">
          <DockPanel>
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}"
                    Content="Riscansiona" Command="{Binding RescanCommand}" VerticalAlignment="Top" />
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                    Content="{Binding ApplyAllLabel}" Command="{Binding ApplyAllCommand}"
                    VerticalAlignment="Top" Margin="0,0,8,0"
                    Visibility="{Binding HasApplicableRecommended, Converter={StaticResource BoolToVis}}" />
            <StackPanel>
              <TextBlock Style="{StaticResource H1}" Text="{Binding Header}" />
              <TextBlock Style="{StaticResource Muted}" Text="{Binding SubHeader}" Margin="0,4,0,0" />
            </StackPanel>
          </DockPanel>

          <!-- First-run onboarding banner (TIER 1): one-time welcome with the real scan results. -->
          <Border CornerRadius="10" Padding="16,13" Margin="0,18,0,0"
                  Background="{DynamicResource Surface2}" BorderBrush="{DynamicResource Accent}"
                  BorderThickness="1"
                  Visibility="{Binding ShowFirstRunHint, Converter={StaticResource BoolToVis}}">
            <DockPanel>
              <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Ho capito"
                      Command="{Binding DismissFirstRunCommand}" VerticalAlignment="Center" Margin="14,0,0,0" />
              <StackPanel>
                <TextBlock Text="Primo avvio" FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource Accent}" />
                <TextBlock Text="{Binding FirstRunHintText}" Style="{StaticResource Muted}"
                           TextWrapping="Wrap" Margin="0,3,0,0" />
              </StackPanel>
            </DockPanel>
          </Border>

          <!-- Card "Rumore di sistema": onestà attiva contro il placebo. Ispirata all'analisi
               di Hone (docs/VS_HONE.md sez. 3.1). Su sistemi puliti, i tweak background non
               produrranno FPS misurabili; su sistemi rumorosi sì, ma comunque con Ghost Tweak.
               Sotto: CTA per Gaming Session Mode (sez. 3.3) che abbassa temporaneamente la
               priority dei bloater conosciuti. Reversibile, non tocca il gioco. -->
          <Border Style="{StaticResource Card}" Margin="0,18,0,0"
                  Visibility="{Binding ShowNoiseCard, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}"
                         Foreground="{Binding NoiseColor, Converter={StaticResource TokenBrush}}"
                         Text="{Binding NoiseHeadline}" />
              <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"
                         Text="{Binding NoiseBody}" />
              <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                         Text="{Binding NoiseFactorsText}" />
              <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                <Button Style="{StaticResource PrimaryButton}"
                        Content="{Binding SessionButtonLabel}"
                        Command="{Binding ToggleSessionCommand}" />
                <TextBlock Style="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center"
                           Margin="12,0,0,0" TextWrapping="Wrap" Text="{Binding SessionStatus}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Card "Pronto per Vanguard": Secure Boot + TPM 2.0 sono prerequisiti di Vanguard
               (Valorant) e Windows 11. Mostrata dopo il primo scan; quando entrambi sono attivi
               diventa la versione verde "Pronto"; quando uno è spento, link diretto alla guida BIOS. -->
          <Border Style="{StaticResource Card}" Margin="0,18,0,0"
                  Visibility="{Binding ShowVanguardCard, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="{Binding VanguardHeadline}" />
              <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,10"
                         Text="Secure Boot + TPM 2.0 sono richiesti da Vanguard (Valorant) e da Windows 11. Se ne manca uno, Vanguard può rifiutare di avviare." />

              <!-- Riga Secure Boot (2ª passata Design: Path icone SVG invece di emoji ✓⚠). -->
              <DockPanel Margin="0,4,0,0">
                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Istruzioni BIOS"
                        Command="{Binding OpenSecureBootGuideCommand}"
                        Visibility="{Binding SecureBootOffUi, Converter={StaticResource BoolToVis}}" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding SecureBootOnUi, Converter={StaticResource BoolToVis}}">
                  <Path Style="{StaticResource IconCheck}" Fill="{DynamicResource Ok}" Margin="0,0,8,0" />
                  <TextBlock FontSize="14" Foreground="{DynamicResource Ok}" Text="Secure Boot attivo" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding SecureBootOffUi, Converter={StaticResource BoolToVis}}">
                  <Path Style="{StaticResource IconWarn}" Fill="{DynamicResource Warn}" Margin="0,0,8,0" />
                  <TextBlock FontSize="14" Foreground="{DynamicResource Warn}" Text="Secure Boot da abilitare" />
                </StackPanel>
              </DockPanel>

              <!-- Riga TPM 2.0 -->
              <DockPanel Margin="0,6,0,0">
                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Istruzioni BIOS"
                        Command="{Binding OpenTpmGuideCommand}"
                        Visibility="{Binding TpmOffUi, Converter={StaticResource BoolToVis}}" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding TpmOnUi, Converter={StaticResource BoolToVis}}">
                  <Path Style="{StaticResource IconCheck}" Fill="{DynamicResource Ok}" Margin="0,0,8,0" />
                  <TextBlock FontSize="14" Foreground="{DynamicResource Ok}" Text="TPM 2.0 attivo" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding TpmOffUi, Converter={StaticResource BoolToVis}}">
                  <Path Style="{StaticResource IconWarn}" Fill="{DynamicResource Warn}" Margin="0,0,8,0" />
                  <TextBlock FontSize="14" Foreground="{DynamicResource Warn}" Text="TPM 2.0 da abilitare" />
                </StackPanel>
              </DockPanel>
            </StackPanel>
          </Border>

          <!-- Verdict Score (Lab feature, default-ON): the honest 0–100 number. -->
          <Border Style="{StaticResource Card}" Margin="0,24,0,0" Padding="20,18"
                  Visibility="{Binding ShowScore, Converter={StaticResource BoolToVis}}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center"
                          MinWidth="120">
                <TextBlock Text="VERDICT SCORE" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}" />
                <TextBlock Style="{StaticResource Mono}" FontSize="56" Margin="0,-2,0,0"
                           Foreground="{Binding ScoreColor, Converter={StaticResource TokenBrush}}"
                           Text="{Binding Score}" />
                <TextBlock Text="{Binding ScoreBand}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{Binding ScoreColor, Converter={StaticResource TokenBrush}}" />
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <ItemsControl ItemsSource="{Binding ScoreBreakdown}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <DockPanel Margin="0,2">
                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource Mono}" FontSize="12"
                                   Foreground="{DynamicResource TextMuted}" Text="{Binding DeltaLabel}" />
                        <TextBlock Style="{StaticResource Muted}" Text="{Binding Text}"
                                   TextWrapping="Wrap" Margin="0,0,12,0" />
                      </DockPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Background="{DynamicResource Surface2}" CornerRadius="4" Padding="10,7"
                        Margin="0,8,0,0">
                  <TextBlock Text="{Binding HonestyNote}" Style="{StaticResource Muted}"
                             FontSize="11" TextWrapping="Wrap" />
                </Border>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Risk Slider (Lab feature): one knob safe↔extreme. Placebos never in scope. -->
          <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="20,16"
                  Visibility="{Binding ShowRiskSlider, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding RiskName}" FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{Binding RiskColor, Converter={StaticResource TokenBrush}}" />
                <TextBlock Text="LIVELLO DI RISCHIO" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
              </DockPanel>
              <Slider Minimum="0" Maximum="3" Value="{Binding RiskLevel}" Margin="0,10,0,0"
                      TickFrequency="1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                      Foreground="{Binding RiskColor, Converter={StaticResource TokenBrush}}" />
              <DockPanel Margin="0,2,0,0">
                <TextBlock Text="Sicuro" FontSize="10" Foreground="{DynamicResource TextMuted}" />
                <TextBlock Text="Estremo" FontSize="10" Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Right" />
              </DockPanel>
              <TextBlock Text="{Binding RiskTagline}" Style="{StaticResource Muted}"
                         TextWrapping="Wrap" Margin="0,8,0,0" />
              <TextBlock Text="{Binding RiskSummary}" Style="{StaticResource Mono}" FontSize="12"
                         Foreground="{DynamicResource Accent}" Margin="0,6,0,0" />
            </StackPanel>
          </Border>

          <!-- Optimize for [game] (Lab feature): pick a title, see its tailored plan. -->
          <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="18,14"
                  Visibility="{Binding ShowOptimizeForGame, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎯" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="Ottimizza per gioco" Style="{StaticResource H2}" Margin="8,0,0,0" />
                <ComboBox ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}"
                          Width="180" Margin="16,0,0,0" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"
                         Text="Scegli un titolo: Verdict raccoglie i tweak di sistema con evidenza + le impostazioni in-game/driver ottimali per QUEL gioco." />
              <Grid Margin="0,12,0,0"
                    Visibility="{Binding SelectedGame, Converter={StaticResource NullToVis}}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                  <TextBlock Text="TWEAK DI SISTEMA" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Accent}" Margin="0,0,0,4" />
                  <ItemsControl ItemsSource="{Binding GameSystemTweaks}">
                    <ItemsControl.ItemTemplate><DataTemplate>
                      <TextBlock Text="{Binding}" Foreground="{DynamicResource Text}"
                                 TextWrapping="Wrap" Margin="0,2" />
                    </DataTemplate></ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock Text="IN-GAME / DRIVER" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Accent}" Margin="0,0,0,4" />
                  <ItemsControl ItemsSource="{Binding GameInGameSettings}">
                    <ItemsControl.ItemTemplate><DataTemplate>
                      <StackPanel Margin="0,2">
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Text}"
                                   FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}"
                                   FontSize="11" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate></ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <UniformGrid Columns="3" Margin="0,24,0,0">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Style="{StaticResource Mono}" FontSize="26"
                           Foreground="{DynamicResource Ok}" Text="{Binding WorthDoing}" />
                <TextBlock Style="{StaticResource H2}" Text="Da fare" Margin="0,8,0,0" />
                <TextBlock Style="{StaticResource Muted}" Text="Miglioramenti gratis con evidenza reale" />
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
              <StackPanel>
                <TextBlock Style="{StaticResource Mono}" FontSize="26"
                           Foreground="{DynamicResource OkDim}" Text="{Binding AlreadyOptimal}" />
                <TextBlock Style="{StaticResource H2}" Text="Già ottimale" Margin="0,8,0,0" />
                <TextBlock Style="{StaticResource Muted}" Text="Niente da fare qui. Ottima notizia." />
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
              <StackPanel>
                <TextBlock Style="{StaticResource Mono}" FontSize="26"
                           Foreground="{DynamicResource Neutral}" Text="{Binding PlaceboAvoided}" />
                <TextBlock Style="{StaticResource H2}" Text="Placebo evitati" Margin="0,8,0,0" />
                <TextBlock Style="{StaticResource Muted}" Text="Tweak famosi che non fanno niente" />
              </StackPanel>
            </Border>
          </UniformGrid>

          <!-- Vista lista: tecnica (default, raggruppata per stato) vs bucket UX (4 macro-categorie
               ispirate da docs/VS_HONE.md sez. 3.2). Toggle persistito in AppSettings. -->
          <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
            <TextBlock Text="Vista:" Style="{StaticResource Muted}" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <RadioButton Content="Per stato (default)" GroupName="verdictListView"
                         IsChecked="{Binding ShowByTechnical, Mode=OneWay}"
                         Click="OnVerdictViewTechnical"
                         VerticalAlignment="Center" Margin="0,0,14,0" />
            <RadioButton Content="Per bucket UX (FPS / Network / QoL / Background)"
                         GroupName="verdictListView"
                         IsChecked="{Binding ShowByBucket, Mode=OneWay}"
                         Click="OnVerdictViewBucket"
                         VerticalAlignment="Center" />
          </StackPanel>

          <ItemsControl ItemsSource="{Binding ActiveGroups}" Margin="0,12,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,0,0,20">
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding BadgeColorKey, Converter={StaticResource TokenBrush}}" />
                    <TextBlock Style="{StaticResource H2}" Text="{Binding Label}" Margin="8,0,8,0" />
                    <TextBlock Style="{StaticResource Mono}" Foreground="{DynamicResource TextMuted}"
                               Text="{Binding Count}" VerticalAlignment="Center" />
                  </StackPanel>
                  <Border Style="{StaticResource Card}" Padding="8">
                    <ItemsControl ItemsSource="{Binding Items}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="8,6">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="300" />
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                              <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="3" Padding="5,1" VerticalAlignment="Center" Margin="0,0,7,0"
                                        Background="{Binding KindColor, Converter={StaticResource TokenBrush}}">
                                  <TextBlock Text="{Binding KindLabel}" FontSize="9" FontWeight="Bold"
                                             Foreground="{DynamicResource OnAccent}" />
                                </Border>
                                <TextBlock Style="{StaticResource Body}" Text="{Binding Name}"
                                           VerticalAlignment="Center" />
                              </StackPanel>
                              <TextBlock Style="{StaticResource Mono}" FontSize="11"
                                         Foreground="{DynamicResource TextMuted}" Text="{Binding Id}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Style="{StaticResource Muted}"
                                       Text="{Binding StatusLine}" VerticalAlignment="Center" Margin="16,0,0,0"
                                       TextWrapping="Wrap" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                              <Button Style="{StaticResource GhostButton}" Content="Come fare"
                                      Padding="10,4" FontSize="12" Margin="8,0,0,0"
                                      Command="{Binding HowToCommand}"
                                      Visibility="{Binding IsManual, Converter={StaticResource BoolToVis}}" />
                              <Button x:Name="biosBtn" Style="{StaticResource GhostButton}" Content="Istruzioni BIOS"
                                      Padding="10,4" FontSize="12" Margin="6,0,0,0"
                                      Command="{Binding ToggleBiosGuideCommand}"
                                      Visibility="{Binding HasBiosGuide, Converter={StaticResource BoolToVis}}" />
                              <Popup IsOpen="{Binding IsBiosPopupOpen, Mode=TwoWay}" StaysOpen="False"
                                     PlacementTarget="{Binding ElementName=biosBtn}" Placement="Bottom"
                                     AllowsTransparency="True">
                                <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Line}"
                                        BorderThickness="1" CornerRadius="12" Padding="16" Margin="8">
                                  <StackPanel Width="236">
                                    <TextBlock Style="{StaticResource H2}" Text="Istruzioni BIOS sul telefono" />
                                    <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap"
                                               Margin="0,4,0,10"
                                               Text="Inquadra il QR: si apre la guida passo-passo per la TUA scheda madre (IT/EN). Funziona anche col PC nel BIOS." />
                                    <Border Background="White" CornerRadius="8" Padding="8" HorizontalAlignment="Center">
                                      <Image Source="{Binding QrImage}" Width="190" Height="190" />
                                    </Border>
                                    <Button Style="{StaticResource GhostButton}" Content="Apri il link nel browser"
                                            Margin="0,10,0,0" Command="{Binding OpenBiosGuideCommand}" />
                                  </StackPanel>
                                </Border>
                              </Popup>
                              <Button Style="{StaticResource GhostButton}" Content="Apri impostazioni"
                                      Padding="10,4" FontSize="12" Margin="6,0,0,0"
                                      Command="{Binding OpenSettingsCommand}"
                                      Visibility="{Binding CanOpenSettings, Converter={StaticResource BoolToVis}}" />
                              <ToggleButton Style="{StaticResource Switch}" Margin="10,0,2,0"
                                            IsChecked="{Binding IsOn, Mode=TwoWay}"
                                            IsEnabled="{Binding ToggleEnabled}"
                                            ToolTip="{Binding StatusLine}" />
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Border>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ============ MEASURE (wizard) ============ -->
    <DataTemplate DataType="{x:Type local:MeasureWizardViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="820" HorizontalAlignment="Left">
          <TextBlock Style="{StaticResource H1}" Text="Misura" />
          <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,16"
                     Text="Baseline → UNA modifica → post → verdetto. Il metodo è il prodotto." />

          <!-- Ghost Tweak (Lab feature): the blind A/B on yourself. -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,16" Padding="18,14"
                  Visibility="{Binding Ghost.ShowGhostTweak, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎭" FontSize="18" VerticalAlignment="Center" />
                <TextBlock Text="Ghost Tweak" Style="{StaticResource H2}" Margin="8,0,0,0" />
                <Border Background="{DynamicResource Surface2}" CornerRadius="3" Padding="5,1"
                        Margin="8,2,0,0" VerticalAlignment="Center">
                  <TextBlock Text="A/B alla cieca" FontSize="10" Foreground="{DynamicResource TextMuted}" />
                </Border>
              </StackPanel>
              <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                         Text="Verdict applica un tweak senza dirti quale. Tu misuri (baseline prima, post dopo). Poi Rivela: scopri cos'era e se ha aiutato DAVVERO. Doppio-cieco su te stesso — uccide il placebo. Il tweak viene sempre annullato alla fine." />
              <TextBlock Style="{StaticResource Body}" Text="{Binding Ghost.Status}" Margin="0,10,0,0"
                         TextWrapping="Wrap" />
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Style="{StaticResource PrimaryButton}" Content="Inizia round cieco"
                        Command="{Binding Ghost.StartRoundCommand}"
                        Visibility="{Binding Ghost.IsApplied, Converter={StaticResource BoolToVisInverted}}" />
                <Button Style="{StaticResource PrimaryButton}" Content="Rivela"
                        Command="{Binding Ghost.RevealCommand}"
                        Visibility="{Binding Ghost.IsApplied, Converter={StaticResource BoolToVis}}" />
              </StackPanel>
              <Border CornerRadius="6" Padding="12,10" Margin="0,12,0,0"
                      Background="{DynamicResource Surface2}"
                      Visibility="{Binding Ghost.IsRevealed, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                  <TextBlock Text="{Binding Ghost.RevealTitle}" FontWeight="SemiBold"
                             Foreground="{Binding Ghost.RevealColor, Converter={StaticResource TokenBrush}}" />
                  <TextBlock Text="{Binding Ghost.RevealPlain}" Style="{StaticResource Muted}"
                             TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <!-- Latency Lab (Lab feature): before/after chart of the last comparison. -->
          <Border Padding="18,14" Margin="0,0,0,16">
            <Border.Style>
              <Style TargetType="Border" BasedOn="{StaticResource Card}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding ShowLatencyLab}" Value="True" />
                      <Condition Binding="{Binding HasLatencyData}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="📈" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="Latency Lab" Style="{StaticResource H2}" Margin="8,0,0,0" />
                <TextBlock Text="before → after (frametime, più corto è meglio)" Style="{StaticResource Muted}"
                           FontSize="11" VerticalAlignment="Center" Margin="10,2,0,0" />
              </StackPanel>
              <ItemsControl ItemsSource="{Binding LatencyRows}" Margin="0,10,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,0,0,10">
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding DeltaLabel}" FontWeight="SemiBold"
                                   Foreground="{Binding DeltaColor, Converter={StaticResource TokenBrush}}" />
                        <TextBlock Text="{Binding Metric}" Foreground="{DynamicResource Text}" FontSize="12" />
                      </DockPanel>
                      <!-- baseline bar -->
                      <Grid Margin="0,4,0,0">
                        <Border Height="14" HorizontalAlignment="Left" CornerRadius="3"
                                Background="{DynamicResource Surface2}" Width="{Binding BaselineBar}" />
                        <TextBlock Text="{Binding BaselineMs, StringFormat=N2}" FontSize="10" Margin="6,0,0,0"
                                   VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" />
                      </Grid>
                      <!-- post bar -->
                      <Grid Margin="0,3,0,0">
                        <Border Height="14" HorizontalAlignment="Left" CornerRadius="3"
                                Background="{Binding DeltaColor, Converter={StaticResource TokenBrush}}"
                                Width="{Binding PostBar}" />
                        <TextBlock Text="{Binding PostMs, StringFormat=N2}" FontSize="10" Margin="6,0,0,0"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Text}" />
                      </Grid>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Reaction Lab (Lab feature): click-when-green reflex minigame. -->
          <Border Style="{StaticResource Card}" Padding="18,14" Margin="0,0,0,16"
                  DataContext="{Binding Reaction}"
                  Visibility="{Binding ShowReactionLab, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="Reaction Lab" Style="{StaticResource H2}" Margin="8,0,0,0" />
                <TextBlock Text="occhio → cervello → mano → schermo" Style="{StaticResource Muted}"
                           FontSize="11" VerticalAlignment="Center" Margin="10,2,0,0" />
              </StackPanel>
              <!-- The big target: click it as soon as it goes green. -->
              <Button Command="{Binding TapCommand}" Height="120" Margin="0,10,0,0"
                      BorderThickness="0" Cursor="Hand">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Border Background="{Binding ColorKey, Converter={StaticResource TokenBrush}}"
                            CornerRadius="10">
                      <TextBlock Text="{Binding Prompt}" Foreground="{DynamicResource Text}"
                                 FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 TextAlignment="Center" Margin="16,0" />
                    </Border>
                  </ControlTemplate>
                </Button.Template>
              </Button>
              <DockPanel Margin="0,10,0,0">
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Avvia"
                        Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}" />
                <ItemsControl ItemsSource="{Binding Samples}" VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Surface2}" CornerRadius="3"
                              Padding="6,2" Margin="0,0,6,0">
                        <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource Text}" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </DockPanel>
              <TextBlock Text="{Binding ResultLine}" Style="{StaticResource Mono}" FontSize="13"
                         Foreground="{DynamicResource Accent}" Margin="0,8,0,0"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <!-- Blockers (F1/F2) -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                  Visibility="{Binding CanMeasure, Converter={StaticResource BoolToVisInverted}}">
            <StackPanel>
              <TextBlock Style="{StaticResource Body}" Text="{Binding BlockerText}" />
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Style="{StaticResource PrimaryButton}" Content="Riavvia come amministratore"
                        Command="{Binding RelaunchAsAdminCommand}"
                        Visibility="{Binding IsElevated, Converter={StaticResource BoolToVisInverted}}" />
                <Button Style="{StaticResource PrimaryButton}" Content="Download PresentMon (10 MB, verified)"
                        Command="{Binding InstallPresentMonCommand}"
                        Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}" />
              </StackPanel>
              <TextBlock Style="{StaticResource Muted}" Text="{Binding Status}" Margin="0,8,0,0" />
            </StackPanel>
          </Border>

          <!-- Step 1: pick -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                  Visibility="{Binding IsStepPick, Converter={StaticResource BoolToVis}}">
            <StackPanel IsEnabled="{Binding CanMeasure}">
              <TextBlock Style="{StaticResource H2}" Text="1 · Scegli gioco e scenario" />
              <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,12"
                         Text="PUOI misurare le partite live — ma di solito sono troppo rumorose per un verdetto. Uno scenario ripetibile è la stessa situazione di gioco a ogni run (stessa mappa e percorso, stesso benchmark), non il replay di una cattura vecchia. Misuriamo comunque e ti diciamo onestamente cosa i dati possono sostenere." />
              <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Aggiorna"
                        Command="{Binding RefreshProcessesCommand}" Margin="8,0,0,0" />
                <ComboBox ItemsSource="{Binding Processes}" SelectedItem="{Binding Target}"
                          DisplayMemberPath="Display" />
              </DockPanel>
              <TextBlock Style="{StaticResource H2}" FontSize="13" Text="Protocollo scenario" Margin="0,16,0,4" />
              <ComboBox ItemsSource="{Binding Scenarios}" SelectedItem="{Binding Scenario}"
                        DisplayMemberPath="Name" />
              <Border Background="{DynamicResource Surface2}" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                <TextBlock Style="{StaticResource Body}" FontSize="12.5"
                           Text="{Binding Scenario.Instructions}" TextWrapping="Wrap" />
              </Border>
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource Body}" Text="Secondi per run" Width="160" VerticalAlignment="Center" />
                <TextBox Text="{Binding Seconds, UpdateSourceTrigger=LostFocus}" Width="64" />
                <TextBlock Style="{StaticResource Muted}" Margin="16,0,0,0" VerticalAlignment="Center">
                  <Run Text="Run per gruppo: " /><Run Text="{Binding Runs, Mode=OneWay}" />
                  <Run Text=" (Impostazioni)" />
                </TextBlock>
              </StackPanel>
              <Button Style="{StaticResource PrimaryButton}" Content="Avvia baseline"
                      Command="{Binding StartBaselineCommand}" Margin="0,16,0,0" HorizontalAlignment="Left" />
            </StackPanel>
          </Border>

          <!-- Step 3: apply ONE change -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                  Visibility="{Binding IsStepApplyChange, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="3 · Applica UNA modifica" />
              <TextBlock Style="{StaticResource Body}" Margin="0,8,0,0"
                         Text="Una modifica alla volta, o non saprai cosa ha fatto cosa. Applicala ora (a mano, o con un tweak di Verdict), poi torna qui." />
              <Button Style="{StaticResource PrimaryButton}" Content="Ho applicato UNA modifica — misura post"
                      Command="{Binding StartPostCommand}" Margin="0,16,0,0" HorizontalAlignment="Left" />
            </StackPanel>
          </Border>

          <!-- Verdict -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                  Visibility="{Binding IsStepVerdict, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="5 · Verdict" />
              <TextBlock Style="{StaticResource Mono}" Margin="0,12,0,0" TextWrapping="Wrap"
                         Text="{Binding VerdictText}" />
              <Button Style="{StaticResource GhostButton}" Content="Ricomincia"
                      Command="{Binding RestartCommand}" Margin="0,16,0,0" HorizontalAlignment="Left" />
            </StackPanel>
          </Border>

          <!-- Run log -->
          <Border Style="{StaticResource Card}" Background="{DynamicResource Surface2}"
                  Visibility="{Binding RunLog.Count, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding RunLog}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Style="{StaticResource Mono}" Text="{Binding}" TextWrapping="Wrap" Margin="0,1" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ============ DIAGNOSTICS ============ -->
    <DataTemplate DataType="{x:Type local:DiagnosticsViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="32,24">
        <TextBlock Style="{StaticResource H1}" Text="Diagnostics" />
        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,16"
                   Text="Latenza DPC/ISR del kernel per driver — trova il vero colpevole dello stutter, o ti dice che non c'è." />
        <TextBlock Style="{StaticResource Body}" Text="{Binding Status}" Margin="0,0,0,12" />
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryButton}" Content="Capture"
                  Command="{Binding CaptureCommand}"
                  Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}" />
          <TextBox Text="{Binding Seconds, UpdateSourceTrigger=LostFocus}" Width="56"
                   Margin="8,0,0,0" VerticalAlignment="Center"
                   Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}" />
          <TextBlock Style="{StaticResource Muted}" Text="seconds" Margin="6,0,0,0" VerticalAlignment="Center"
                     Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}" />
          <Button Style="{StaticResource PrimaryButton}" Content="Riavvia come amministratore"
                  Command="{Binding RelaunchAsAdminCommand}"
                  Visibility="{Binding IsElevated, Converter={StaticResource BoolToVisInverted}}" />
        </StackPanel>
        <TextBlock Style="{StaticResource H2}" Foreground="{DynamicResource Accent}"
                   Text="{Binding VerdictLine}" Margin="0,16,0,8" TextWrapping="Wrap" />

        <!-- Explain my Stutter (Lab feature): the raw DPC table in plain Italian. -->
        <Border Padding="16,14" Margin="0,0,0,10">
          <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource Card}">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding ShowStutterExplain}" Value="True" />
                    <Condition Binding="{Binding HasStutterResult}" Value="True" />
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
              <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                       Fill="{Binding StutterColor, Converter={StaticResource TokenBrush}}" />
              <TextBlock Text="Explain my Stutter" FontWeight="SemiBold" Margin="8,0,0,0"
                         Foreground="{DynamicResource Text}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding StutterHeadline}" TextWrapping="Wrap" Margin="0,4,0,0"
                       Foreground="{Binding StutterColor, Converter={StaticResource TokenBrush}}" />
            <ItemsControl ItemsSource="{Binding StutterFindings}" Margin="0,8,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource Surface2}" CornerRadius="6" Padding="12,9" Margin="0,4,0,0">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                 Fill="{Binding ColorKey, Converter={StaticResource TokenBrush}}" />
                        <TextBlock Text="{Binding Component}" FontWeight="SemiBold" Margin="7,0,0,0"
                                   Foreground="{DynamicResource Text}" />
                      </StackPanel>
                      <TextBlock Text="{Binding Plain}" Style="{StaticResource Muted}"
                                 TextWrapping="Wrap" Margin="0,3,0,0" />
                      <TextBlock Text="{Binding Tip}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                 Foreground="{DynamicResource Accent}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}" Padding="8"
                Visibility="{Binding Rows.Count, Converter={StaticResource BoolToVis}}">
          <ItemsControl ItemsSource="{Binding Rows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="8,3">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Style="{StaticResource Mono}" Text="{Binding Driver}" />
                  <TextBlock Grid.Column="1" Style="{StaticResource Mono}" Text="{Binding Events}"
                             Foreground="{DynamicResource TextMuted}" />
                  <TextBlock Grid.Column="2" Style="{StaticResource Mono}" Text="{Binding MaxUs}" />
                  <TextBlock Grid.Column="3" Style="{StaticResource Mono}" Text="{Binding AvgUs}"
                             Foreground="{DynamicResource TextMuted}" />
                  <TextBlock Grid.Column="4" Style="{StaticResource Mono}" Text="{Binding Spikes}"
                             Foreground="{DynamicResource TextMuted}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>

        <!-- Network Duel (Lab feature): route quality toward public anchors. -->
        <Border Style="{StaticResource Card}" Margin="0,16,0,0" Padding="16,14"
                Visibility="{Binding ShowNetworkDuel, Converter={StaticResource BoolToVis}}">
          <StackPanel>
            <DockPanel>
              <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Test rete"
                      Command="{Binding RunNetworkDuelCommand}" VerticalAlignment="Center" />
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="🛰" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="Network Duel" Style="{StaticResource H2}" Margin="8,0,0,0" />
              </StackPanel>
            </DockPanel>
            <TextBlock Text="{Binding NetStatus}" Style="{StaticResource Muted}" Margin="0,6,0,0"
                       TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding NetResults}" Margin="0,10,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="2*" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Target}" Foreground="{DynamicResource Text}"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12"
                               Foreground="{DynamicResource TextMuted}">
                      <Run Text="{Binding AvgMs, StringFormat=N0}" /><Run Text=" ms · jit " /><Run Text="{Binding JitterMs, StringFormat=N0}" /><Run Text=" · loss " /><Run Text="{Binding LossPercent, StringFormat=N0}" /><Run Text="%" />
                    </TextBlock>
                    <Border Grid.Column="2" Background="{DynamicResource Surface2}" CornerRadius="3"
                            Padding="6,1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Grade}" FontSize="11" FontWeight="SemiBold"
                                 Foreground="{Binding GradeColor, Converter={StaticResource TokenBrush}}" />
                    </Border>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ============ KNOWLEDGE BASE ============ -->
    <DataTemplate DataType="{x:Type local:KbViewModel}">
      <Grid Margin="32,24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
          <TextBlock Style="{StaticResource H1}" Text="Knowledge Base" VerticalAlignment="Center" />
          <ComboBox ItemsSource="{Binding Filters}" SelectedItem="{Binding Filter}"
                    Margin="24,0,0,0" Width="180" VerticalAlignment="Center" />
          <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                   Width="220" Margin="12,0,0,0" VerticalAlignment="Center"
                   ToolTip="Cerca per nome, id o descrizione" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,16,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Style="{StaticResource Card}" Padding="4">
            <ListBox ItemsSource="{Binding Entries}" SelectedItem="{Binding Selected}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <DockPanel Margin="4,4" LastChildFill="True">
                    <Border DockPanel.Dock="Right" Style="{StaticResource Badge}"
                            Background="{Binding Badge.ColorKey, Converter={StaticResource TokenBrush}}">
                      <TextBlock Text="{Binding Badge.Label}" FontSize="11" Foreground="{DynamicResource OnAccent}" />
                    </Border>
                    <StackPanel>
                      <TextBlock Style="{StaticResource Body}" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                      <TextBlock Style="{StaticResource Mono}" FontSize="11"
                                 Foreground="{DynamicResource TextMuted}" Text="{Binding Id}" />
                    </StackPanel>
                  </DockPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource Card}" Margin="16,0,0,0"
                  Visibility="{Binding Selected, Converter={StaticResource NullToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel DataContext="{Binding Selected}">
                <TextBlock Style="{StaticResource H2}" Text="{Binding Name}" />
                <TextBlock Style="{StaticResource Mono}" FontSize="11" Margin="0,2,0,12"
                           Foreground="{DynamicResource TextMuted}" Text="{Binding Id}" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding Entry.Description}" />
                <TextBlock Style="{StaticResource H2}" Text="Expected impact" Margin="0,16,0,4" FontSize="13" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding Entry.ExpectedImpact}" />
                <TextBlock Style="{StaticResource H2}" Text="Come fare (manuale)" Margin="0,16,0,4" FontSize="13" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding Entry.ManualSteps}" />
                <TextBlock Style="{StaticResource H2}" Text="Rollback" Margin="0,16,0,4" FontSize="13" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding Entry.Rollback}" />
                <TextBlock Style="{StaticResource H2}" Text="Sources" Margin="0,16,0,4" FontSize="13" />
                <ItemsControl ItemsSource="{Binding Entry.Sources}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Style="{StaticResource Mono}" FontSize="11" Text="{Binding}"
                                 Foreground="{DynamicResource Info}" TextWrapping="Wrap" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Border>

          <!-- Placebo Museum (Lab feature): shown in the detail pane when nothing is selected. -->
          <Border Grid.Column="1" Margin="16,0,0,0">
            <Border.Style>
              <Style TargetType="Border" BasedOn="{StaticResource Card}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding ShowPlaceboMuseum}" Value="True" />
                      <Condition Binding="{Binding Selected}" Value="{x:Null}" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="🏛" FontSize="18" VerticalAlignment="Center" />
                  <TextBlock Text="Placebo Museum" Style="{StaticResource H2}" Margin="8,0,0,0" />
                </StackPanel>
                <TextBlock Text="{Binding MuseumSummary}" Style="{StaticResource Muted}" Margin="0,2,0,2" />
                <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"
                           Text="I tweak che TUTTI consigliano ma che non fanno niente di misurabile. Non ci sei cascato." />
                <ItemsControl ItemsSource="{Binding Museum}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Surface2}" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                        <StackPanel>
                          <DockPanel>
                            <Border DockPanel.Dock="Right" Background="{DynamicResource Neutral}" CornerRadius="3"
                                    Padding="6,1" VerticalAlignment="Center">
                              <TextBlock Text="PLACEBO" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource OnAccent}" />
                            </Border>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text}" VerticalAlignment="Center" />
                          </DockPanel>
                          <TextBlock Margin="0,5,0,0" TextWrapping="Wrap">
                            <Run Text="Il mito: " Foreground="{DynamicResource TextMuted}" FontSize="11" /><Run Text="{Binding Myth}" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                          </TextBlock>
                          <TextBlock Margin="0,3,0,0" TextWrapping="Wrap">
                            <Run Text="La verità: " Foreground="{DynamicResource Danger}" FontSize="11" FontWeight="SemiBold" /><Run Text="{Binding Truth}" Foreground="{DynamicResource Text}" FontSize="11" />
                          </TextBlock>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>
        <TextBlock Grid.Row="2" Style="{StaticResource Muted}" Text="{Binding Footer}" Margin="0,12,0,0" />
      </Grid>
    </DataTemplate>

    <!-- ============ REPORT ============ -->
    <DataTemplate DataType="{x:Type local:ReportViewModel}">
      <StackPanel Margin="32,24" MaxWidth="720" HorizontalAlignment="Left">
        <TextBlock Style="{StaticResource H1}" Text="Report" />
        <TextBlock Style="{StaticResource Body}" Text="{Binding Status}" Margin="0,12,0,16" />
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryButton}" Content="Genera report"
                  Command="{Binding GenerateCommand}" />
          <Button Style="{StaticResource GhostButton}" Content="Apri ultimo report"
                  Command="{Binding OpenCommand}" Margin="12,0,0,0"
                  Visibility="{Binding LastPath, Converter={StaticResource NullToVis}}" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- ============ CHANGES (undo journal) ============ -->
    <!-- ============ SCAN (build-sheet) ============ -->
    <DataTemplate DataType="{x:Type local:ScanViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="720" HorizontalAlignment="Left">
          <DockPanel Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="{Binding RescanLabel}"
                    Command="{Binding RescanCommand}" VerticalAlignment="Top" />
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="Esporta PNG"
                    Click="OnExportBuildSheet" VerticalAlignment="Top" Margin="0,0,8,0" />
            <StackPanel>
              <TextBlock Style="{StaticResource H1}" Text="Scansione" />
              <TextBlock Style="{StaticResource Muted}"
                         Text="Inventario hardware completo (WMI, nessun driver) — esportabile come immagine." />
            </StackPanel>
          </DockPanel>

          <!-- The exported card: only this element is rendered to PNG. -->
          <Border x:Name="BuildSheet" Background="{DynamicResource Bg}" CornerRadius="14"
                  BorderBrush="{DynamicResource Accent}" BorderThickness="1" Padding="24">
            <StackPanel>
              <TextBlock Text="LÉON'S RIG" FontSize="13" FontWeight="Bold" Opacity="0.7"
                         Foreground="{DynamicResource Accent}" />
              <TextBlock Text="{Binding LastScanned}" FontSize="11" Opacity="0.6"
                         Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0" />

              <!-- Rig DNA (Lab feature): the build's collectible identity, tinted by its hue. -->
              <Border Margin="0,14,0,0" CornerRadius="10" Padding="0"
                      Background="{DynamicResource Surface}" BorderThickness="1"
                      BorderBrush="{Binding RigTint}"
                      Visibility="{Binding ShowRigDna, Converter={StaticResource BoolToVis}}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0" Background="{Binding RigTint}"
                          CornerRadius="10,0,0,10" />
                  <StackPanel Grid.Column="1" Margin="14,11">
                    <DockPanel>
                      <Border DockPanel.Dock="Right" CornerRadius="4" Padding="7,2"
                              Background="{DynamicResource Surface2}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RigTier}" FontSize="11" FontWeight="Bold"
                                   Foreground="{Binding RigTierColor, Converter={StaticResource TokenBrush}}" />
                      </Border>
                      <TextBlock Text="RIG DNA" FontSize="10" FontWeight="Bold" Opacity="0.6"
                                 Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                    </DockPanel>
                    <TextBlock Text="{Binding RigCode}" Style="{StaticResource Mono}" FontSize="22"
                               Foreground="{Binding RigTint}" Margin="0,2,0,0" />
                    <ItemsControl ItemsSource="{Binding RigTraits}" Margin="0,6,0,0">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{DynamicResource Surface2}" CornerRadius="3"
                                  Padding="6,2" Margin="0,0,6,0">
                            <TextBlock Text="{Binding}" FontSize="11"
                                       Foreground="{DynamicResource Text}" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Grid>
              </Border>

              <Border Height="1" Background="{DynamicResource Line}" Margin="0,14" />

              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Processore" Style="{StaticResource Muted}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Cpu}" Foreground="{DynamicResource Text}" FontWeight="SemiBold" TextWrapping="Wrap" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding GpuPrimaryLabel}" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GpuPrimary}" Foreground="{DynamicResource Text}" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Scheda grafica integrata" Style="{StaticResource Muted}" Margin="0,6,0,0"
                           Visibility="{Binding HasIntegratedGpu, Converter={StaticResource BoolToVis}}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GpuIntegrated}" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" TextWrapping="Wrap"
                           Visibility="{Binding HasIntegratedGpu, Converter={StaticResource BoolToVis}}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Scheda madre" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Motherboard}" Foreground="{DynamicResource Text}" Margin="0,6,0,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="BIOS" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Bios}" Foreground="{DynamicResource Text}" Margin="0,6,0,0" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="RAM" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,6,0,0">
                  <TextBlock Text="{Binding Ram}" Foreground="{DynamicResource Text}" />
                  <ItemsControl ItemsSource="{Binding MemoryModules}">
                    <ItemsControl.ItemTemplate><DataTemplate>
                      <TextBlock Text="{Binding}" Style="{StaticResource Mono}" FontSize="11"
                                 Foreground="{DynamicResource TextMuted}" />
                    </DataTemplate></ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Dischi" Style="{StaticResource Muted}" Margin="0,6,0,0" />
                <ItemsControl Grid.Row="6" Grid.Column="1" ItemsSource="{Binding Disks}" Margin="0,6,0,0">
                  <ItemsControl.ItemTemplate><DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="{DynamicResource Text}" />
                  </DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>

              <!-- Sezione findings/diagnosi RIMOSSA (Léon 2026-06-22): il build-sheet è solo
                   inventario COMPONENTI, niente nag tipo "RAM 5600 vs 6000" o driver nvidia. -->

              <!-- Multi-monitor optimizer (Lab feature): shown only when the module is on. -->
              <StackPanel Visibility="{Binding ShowMultiMonitor, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="{DynamicResource Line}" Margin="0,14" />
                <TextBlock Text="MONITOR" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent}" Margin="0,0,0,4" />
                <ItemsControl ItemsSource="{Binding Displays}">
                  <ItemsControl.ItemTemplate><DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="{DynamicResource Text}" Margin="0,1" />
                  </DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding MonitorFindings}" Margin="0,8,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="{Binding Mark}" Foreground="{Binding ColorKey, Converter={StaticResource TokenBrush}}"
                                   FontWeight="Bold" Width="18" />
                        <TextBlock Text="{Binding Text}" Foreground="{DynamicResource Text}" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Fresh-install score (Lab feature): third-party startup drift. -->
              <StackPanel Visibility="{Binding ShowFreshInstall, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="{DynamicResource Line}" Margin="0,14" />
                <DockPanel>
                  <Border DockPanel.Dock="Right" Background="{DynamicResource Surface2}" CornerRadius="6"
                          Padding="10,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding FreshScore}" Style="{StaticResource Mono}" FontSize="22"
                                 Foreground="{Binding FreshColor, Converter={StaticResource TokenBrush}}" />
                      <TextBlock Text="/100" Foreground="{DynamicResource TextMuted}" FontSize="12"
                                 VerticalAlignment="Bottom" Margin="1,0,6,3" />
                      <TextBlock Text="{Binding FreshBand}" FontSize="12" FontWeight="SemiBold"
                                 VerticalAlignment="Center"
                                 Foreground="{Binding FreshColor, Converter={StaticResource TokenBrush}}" />
                    </StackPanel>
                  </Border>
                  <TextBlock Text="FRESH-INSTALL" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                </DockPanel>
                <TextBlock Text="{Binding FreshHeadline}" Style="{StaticResource Muted}"
                           TextWrapping="Wrap" Margin="0,8,0,0" />
                <ItemsControl ItemsSource="{Binding FreshThirdParty}" Margin="0,8,0,0">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Surface2}" CornerRadius="3"
                              Padding="6,2" Margin="0,0,6,6">
                        <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource Text}" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Time Machine (Lab feature): what changed since last snapshot. -->
              <StackPanel Visibility="{Binding ShowTimeMachine, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="{DynamicResource Line}" Margin="0,14" />
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="⏳" FontSize="14" VerticalAlignment="Center" />
                  <TextBlock Text="TIME MACHINE" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Accent}" Margin="7,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding TimelineHeadline}" Style="{StaticResource Muted}"
                           TextWrapping="Wrap" Margin="0,6,0,0" />
                <ItemsControl ItemsSource="{Binding TimelineChanges}" Margin="0,4,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="160" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Field}" Foreground="{DynamicResource Text}"
                                   FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="12" TextWrapping="Wrap">
                          <Run Text="{Binding Before}" Foreground="{DynamicResource TextMuted}" /><Run Text="  →  " Foreground="{DynamicResource TextMuted}" /><Run Text="{Binding After}" Foreground="{DynamicResource Accent}" />
                        </TextBlock>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <TextBlock Text="Verdict — scansione" FontSize="10" Opacity="0.4"
                         Foreground="{DynamicResource TextMuted}" Margin="0,14,0,0" HorizontalAlignment="Right" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:ChangesViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="32,24" MaxWidth="820" HorizontalAlignment="Left">
        <DockPanel>
          <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Ripristina tutto"
                  Command="{Binding RevertAllCommand}" VerticalAlignment="Top"
                  Visibility="{Binding HasRevertableSessions, Converter={StaticResource BoolToVis}}" />
          <TextBlock Style="{StaticResource H1}" Text="Modifiche" />
        </DockPanel>
        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,16"
                   Text="Ogni modifica che Verdict ha applicato, dalla più recente. Tutto è tracciato e reversibile — l'annulla ripristina il valore precedente esatto." />
        <Border Style="{StaticResource Card}" Padding="20"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
          <TextBlock Style="{StaticResource Muted}"
                     Text="Nessuna modifica applicata. Verdict non ha scritto niente nel tuo sistema." />
        </Border>
        <ItemsControl ItemsSource="{Binding Sessions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="16,12">
                <DockPanel>
                  <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Annulla"
                          Command="{Binding DataContext.UndoCommand,
                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}" VerticalAlignment="Top"
                          IsEnabled="{Binding AllUndone, Converter={StaticResource InverseBool}}" />
                  <StackPanel>
                    <TextBlock Style="{StaticResource Body}" Text="{Binding Display}" />
                    <TextBlock Style="{StaticResource Mono}" FontSize="11" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextMuted}" Text="{Binding Detail}" />
                  </StackPanel>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock Style="{StaticResource Muted}" Text="{Binding Status}" Margin="0,8,0,0" />

        <Border Style="{StaticResource Card}" Margin="0,20,0,0" Padding="16,14">
          <StackPanel>
            <TextBlock Style="{StaticResource Body}" Text="Verifica del motore di apply" />
            <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,8"
                       Text="Esegue write→verify→undo su una chiave di registro usa-e-getta (nessuna impostazione reale toccata). Conferma che gli apply funzionano su questo PC." />
            <Button Style="{StaticResource GhostButton}" Content="Verifica motore"
                    HorizontalAlignment="Left" Command="{Binding SelfTestCommand}" />
            <TextBlock Style="{StaticResource Mono}" FontSize="12" Margin="0,10,0,0"
                       TextWrapping="Wrap" Text="{Binding SelfTestStatus}" />
          </StackPanel>
        </Border>

        <!-- Watchdog (Lab feature): on-demand drift check (EXPO, reverted tweaks, startup bloat). -->
        <Border Style="{StaticResource Card}" Margin="0,28,0,0" Padding="16,14"
                DataContext="{Binding Watchdog}"
                Visibility="{Binding ShowWatchdog, Converter={StaticResource BoolToVis}}">
          <StackPanel>
            <DockPanel>
              <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Controlla ora"
                      Command="{Binding CheckCommand}" VerticalAlignment="Center" />
              <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                         Fill="{Binding WorstColor, Converter={StaticResource TokenBrush}}" />
                <TextBlock Text="🛡" FontSize="15" Margin="8,0,0,0" VerticalAlignment="Center" />
                <TextBlock Text="Watchdog" Style="{StaticResource H2}" Margin="6,0,0,0" />
              </StackPanel>
            </DockPanel>
            <TextBlock Text="{Binding Status}" Style="{StaticResource Muted}" Margin="0,6,0,0"
                       TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding Alerts}" Margin="0,8,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource Surface2}" CornerRadius="6" Padding="12,9" Margin="0,4,0,0">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                 Fill="{Binding ColorKey, Converter={StaticResource TokenBrush}}" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="7,0,0,0"
                                   Foreground="{DynamicResource Text}" />
                      </StackPanel>
                      <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}"
                                 TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <DockPanel Margin="0,12,0,0">
              <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                      Content="Avvia in background" Command="{Binding StartTrayCommand}"
                      VerticalAlignment="Center" Margin="12,0,0,0" />
              <TextBlock Style="{StaticResource Muted}" VerticalAlignment="Center" TextWrapping="Wrap"
                         Text="Sorveglianza continua: un'icona nel tray controlla ogni 10 minuti e ti avvisa SOLO quando qualcosa cambia (EXPO spento, un tweak annullato, bloat all'avvio). Sola lettura, non tocca niente." />
            </DockPanel>
            <CheckBox Content="Avvia la sorveglianza all'avvio di Windows (reversibile)" Margin="0,10,0,0"
                      IsChecked="{Binding AutostartEnabled}" Foreground="{DynamicResource Text}" />
          </StackPanel>
        </Border>

        <!-- Trust mode (Lab feature): the full security-review manifest of what Verdict could touch. -->
        <StackPanel Margin="0,28,0,0"
                    Visibility="{Binding ShowTrustMode, Converter={StaticResource BoolToVis}}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource H2}" Text="Trust mode" />
            <Border Background="{DynamicResource Surface2}" CornerRadius="3" Padding="6,2"
                    VerticalAlignment="Center" Margin="10,2,0,0">
              <TextBlock Text="{Binding TrustSummary}" FontSize="11"
                         Foreground="{DynamicResource TextMuted}" />
            </Border>
          </StackPanel>
          <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,8" TextWrapping="Wrap"
                     Text="Esattamente cosa Verdict scriverebbe, voce per voce. Solo lettura: questo è un manifesto, non applica niente. Per chi vuole vedere il diff prima di fidarsi." />
          <ItemsControl ItemsSource="{Binding TrustEntries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource Card}" Margin="0,0,0,6" Padding="14,10">
                  <StackPanel>
                    <TextBlock Text="{Binding TweakName}" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text}" />
                    <TextBlock Text="{Binding TweakId}" Style="{StaticResource Mono}" FontSize="11"
                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding Operations}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource AccentDeep}" CornerRadius="3"
                                    Padding="6,1" VerticalAlignment="Top" Margin="0,1,10,0">
                              <TextBlock Text="{Binding Method}" FontSize="10" FontWeight="SemiBold"
                                         Foreground="{DynamicResource Accent}" />
                            </Border>
                            <StackPanel Grid.Column="1">
                              <TextBlock Text="{Binding Target}" Style="{StaticResource Mono}" FontSize="12"
                                         Foreground="{DynamicResource Text}" TextWrapping="Wrap" />
                              <TextBlock Style="{StaticResource Mono}" FontSize="11"
                                         Foreground="{DynamicResource TextMuted}">
                                <Run Text="→ " /><Run Text="{Binding NewValue}" /><Run Text="  (" /><Run Text="{Binding Kind}" /><Run Text=")" />
                              </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                              <TextBlock Text="admin" FontSize="10" Foreground="{DynamicResource Warn}"
                                         HorizontalAlignment="Right"
                                         Visibility="{Binding NeedsAdmin, Converter={StaticResource BoolToVis}}" />
                              <TextBlock Text="reversibile" FontSize="10" Foreground="{DynamicResource Ok}"
                                         HorizontalAlignment="Right"
                                         Visibility="{Binding Reversible, Converter={StaticResource BoolToVis}}" />
                              <TextBlock Text="reboot" FontSize="10" Foreground="{DynamicResource TextMuted}"
                                         HorizontalAlignment="Right"
                                         Visibility="{Binding RequiresReboot, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ============ PROFILES (V3 §2) ============ -->
    <DataTemplate DataType="{x:Type local:ProfilesViewModel}">
      <Grid Margin="32,24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel>
          <TextBlock Style="{StaticResource H1}" Text="Profili &amp; batch" />
          <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                     Text="Spunta i tweak che vuoi, applicali in blocco (ognuno resta annullabile singolarmente) o salvali come profilo riusabile. Niente placebo, niente gui-only: solo ciò che Verdict può applicare." />
          <TextBlock Style="{StaticResource Muted}" Text="{Binding Status}" Margin="0,6,0,0"
                     Foreground="{DynamicResource Accent}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Saved profiles -->
          <Border Style="{StaticResource Card}" Padding="12">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Style="{StaticResource H2}" Text="Profili salvati" Margin="0,0,0,8" />
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Profiles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Surface2}" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                        <StackPanel>
                          <DockPanel>
                            <Border DockPanel.Dock="Right" Background="{DynamicResource Bg}" CornerRadius="3"
                                    Padding="5,1" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Count}" FontSize="11" Foreground="{DynamicResource TextMuted}" />
                            </Border>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Text}" />
                          </DockPanel>
                          <TextBlock Text="{Binding Description}" Style="{StaticResource Muted}"
                                     FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" />
                          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Applica" Style="{StaticResource GhostButton}" Padding="8,3"
                                    Command="{Binding DataContext.ApplyProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                            <Button Content="Carica" Style="{StaticResource GhostButton}" Padding="8,3" Margin="6,0,0,0"
                                    Command="{Binding DataContext.LoadProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                            <Button Content="Elimina" Style="{StaticResource GhostButton}" Padding="8,3" Margin="6,0,0,0"
                                    Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding BuiltIn, Converter={StaticResource BoolToVisInverted}}" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </Border>

          <!-- Checkbox tweak picker -->
          <Border Grid.Column="1" Style="{StaticResource Card}" Margin="16,0,0,0" Padding="12">
            <DockPanel>
              <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Content="{Binding SelectionLabel}" Command="{Binding ApplySelectedCommand}"
                        IsEnabled="{Binding HasSelection}" />
                <TextBlock Style="{StaticResource H2}" Text="Scegli i tweak" VerticalAlignment="Center" />
              </DockPanel>
              <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                <TextBox Width="220" VerticalAlignment="Center"
                         Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Nome del nuovo profilo" />
                <Button Content="Salva come profilo" Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                        Command="{Binding SaveProfileCommand}" />
              </StackPanel>
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Tweaks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding IsSelected}" Margin="0,3"
                                Foreground="{DynamicResource Text}">
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Text}" />
                          <TextBlock Text="{Binding Category}" Foreground="{DynamicResource TextMuted}"
                                     FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                      </CheckBox>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </Border>
        </Grid>
      </Grid>
    </DataTemplate>

    <!-- ============ SETTINGS ============ -->
    <DataTemplate DataType="{x:Type local:LabViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="760" HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource H1}" Text="Lab" />
            <Border Background="{DynamicResource AccentDeep}" CornerRadius="4" Padding="7,2"
                    VerticalAlignment="Center" Margin="12,4,0,0">
              <TextBlock Text="{Binding Summary}" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource Accent}" />
            </Border>
          </StackPanel>
          <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,8" TextWrapping="Wrap"
                     Text="{Binding Intro}" />

          <ItemsControl ItemsSource="{Binding Groups}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,12,0,0">
                  <TextBlock Style="{StaticResource H2}" Text="{Binding Name}" Margin="0,0,0,6" />
                  <ItemsControl ItemsSource="{Binding Features}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,6" Padding="14,12">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontSize="20"
                                       VerticalAlignment="Center" Margin="0,0,14,0"
                                       Foreground="{DynamicResource Accent}" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                              <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{DynamicResource Text}" VerticalAlignment="Center" />
                                <Border Background="{DynamicResource Surface2}" CornerRadius="3"
                                        Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding StatusLabel}" FontSize="9"
                                             Foreground="{DynamicResource TextMuted}" />
                                </Border>
                                <Border Background="{DynamicResource Surface2}" CornerRadius="3"
                                        Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsHeavy, Converter={StaticResource BoolToVis}}">
                                  <TextBlock Text="{Binding HeavyLabel}" FontSize="9"
                                             Foreground="{DynamicResource Warn}" />
                                </Border>
                                <Border Background="{DynamicResource AccentDeep}" CornerRadius="3"
                                        Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsComingSoon, Converter={StaticResource BoolToVis}}">
                                  <TextBlock Text="IN ARRIVO" FontSize="9"
                                             Foreground="{DynamicResource Accent}" />
                                </Border>
                              </StackPanel>
                              <TextBlock Text="{Binding Tagline}" Style="{StaticResource Muted}"
                                         TextWrapping="Wrap" Margin="0,3,12,0" />
                              <TextBlock Text="{Binding WhereLabel}" FontSize="11" FontWeight="SemiBold"
                                         Foreground="{DynamicResource Accent}" Margin="0,3,12,0"
                                         Visibility="{Binding HasWhere, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <CheckBox Grid.Column="2" IsChecked="{Binding Enabled}"
                                      IsEnabled="{Binding IsAvailable}" VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:CoPilotViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="720" HorizontalAlignment="Left">
          <TextBlock Style="{StaticResource H1}" Text="Co-pilota" />
          <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                     Text="Chiedi in parole tue. L'AI interpreta e cita SOLO tweak verificati di Verdict — non inventa, e non applica nulla da sola. Scegli il cervello: Ollama locale (privato) o Claude cloud (qualità superiore, manda la domanda a Anthropic)." />

          <WrapPanel Orientation="Horizontal" Margin="0,12,0,0">
            <TextBlock Text="Cervello:" Style="{StaticResource Muted}" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,10,4" />
            <RadioButton Content="Ollama (locale)" GroupName="copilotBrain"
                         IsChecked="{Binding IsOllama, Mode=TwoWay}"
                         VerticalAlignment="Center" Margin="0,0,14,4" />
            <RadioButton Content="Claude (cloud)" GroupName="copilotBrain"
                         IsChecked="{Binding IsClaude, Mode=TwoWay}"
                         VerticalAlignment="Center" Margin="0,0,14,4" />
            <RadioButton Content="Gemini (cloud)" GroupName="copilotBrain"
                         IsChecked="{Binding IsGemini, Mode=TwoWay}"
                         VerticalAlignment="Center" Margin="0,0,14,4" />
            <RadioButton Content="GPT (cloud)" GroupName="copilotBrain"
                         IsChecked="{Binding IsOpenAi, Mode=TwoWay}"
                         VerticalAlignment="Center" Margin="0,0,0,4" />
          </WrapPanel>

          <Border Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
              <TextBox Text="{Binding Question, UpdateSourceTrigger=PropertyChanged}"
                       MinHeight="44" TextWrapping="Wrap" AcceptsReturn="False"
                       VerticalContentAlignment="Center" Foreground="{DynamicResource Text}">
                <TextBox.InputBindings>
                  <KeyBinding Key="Enter" Command="{Binding AskCommand}" />
                </TextBox.InputBindings>
              </TextBox>

              <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                          Visibility="{Binding IsOllama, Converter={StaticResource BoolToVis}}">
                <Button Style="{StaticResource PrimaryButton}" Content="Chiedi"
                        Command="{Binding AskCommand}" IsEnabled="{Binding CanAsk}" />
                <TextBlock Text="Modello Ollama:" Style="{StaticResource Muted}" FontSize="11"
                           VerticalAlignment="Center" Margin="16,0,6,0" />
                <TextBox Text="{Binding Model, UpdateSourceTrigger=LostFocus}" Width="170"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                         Foreground="{DynamicResource Text}"
                         ToolTip="Il modello che hai in Ollama (es. qwen2.5vl:32b). Vuoto = qwen2.5." />
              </StackPanel>

              <StackPanel Margin="0,12,0,0"
                          Visibility="{Binding IsClaude, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                  <Button Style="{StaticResource PrimaryButton}" Content="Chiedi"
                          Command="{Binding AskCommand}" IsEnabled="{Binding CanAsk}" />
                  <TextBlock Text="Modello Claude:" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="16,0,6,0" />
                  <TextBox Text="{Binding ClaudeModel, UpdateSourceTrigger=LostFocus}" Width="220"
                           VerticalAlignment="Center" VerticalContentAlignment="Center"
                           Foreground="{DynamicResource Text}"
                           ToolTip="claude-sonnet-4-6 (default), claude-opus-4-8, claude-haiku-4-5-20251001…" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                  <TextBlock Text="API key Anthropic:" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="0,0,6,0" />
                  <PasswordBox x:Name="ClaudeApiKeyBox" Width="280"
                               VerticalAlignment="Center" VerticalContentAlignment="Center"
                               Foreground="{DynamicResource Text}"
                               PasswordChanged="OnClaudeApiKeyChanged"
                               ToolTip="Salvata cifrata DPAPI sul tuo PC. Vuoto = co-pilota non chiamabile." />
                  <TextBlock Text="✓ configurata" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="10,0,0,0"
                             Visibility="{Binding HasClaudeApiKey, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
              </StackPanel>

              <StackPanel Margin="0,12,0,0"
                          Visibility="{Binding IsGemini, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                  <Button Style="{StaticResource PrimaryButton}" Content="Chiedi"
                          Command="{Binding AskCommand}" IsEnabled="{Binding CanAsk}" />
                  <TextBlock Text="Modello Gemini:" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="16,0,6,0" />
                  <TextBox Text="{Binding GeminiModel, UpdateSourceTrigger=LostFocus}" Width="220"
                           VerticalAlignment="Center" VerticalContentAlignment="Center"
                           Foreground="{DynamicResource Text}"
                           ToolTip="gemini-2.5-pro (default), gemini-2.5-flash (più economico)…" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                  <TextBlock Text="API key Google AI:" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="0,0,6,0" />
                  <PasswordBox x:Name="GeminiApiKeyBox" Width="280"
                               VerticalAlignment="Center" VerticalContentAlignment="Center"
                               Foreground="{DynamicResource Text}"
                               PasswordChanged="OnGeminiApiKeyChanged"
                               ToolTip="Da aistudio.google.com. Salvata cifrata DPAPI sul tuo PC." />
                  <TextBlock Text="✓ configurata" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="10,0,0,0"
                             Visibility="{Binding HasGeminiApiKey, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
              </StackPanel>

              <StackPanel Margin="0,12,0,0"
                          Visibility="{Binding IsOpenAi, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                  <Button Style="{StaticResource PrimaryButton}" Content="Chiedi"
                          Command="{Binding AskCommand}" IsEnabled="{Binding CanAsk}" />
                  <TextBlock Text="Modello OpenAI:" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="16,0,6,0" />
                  <TextBox Text="{Binding OpenAiModel, UpdateSourceTrigger=LostFocus}" Width="220"
                           VerticalAlignment="Center" VerticalContentAlignment="Center"
                           Foreground="{DynamicResource Text}"
                           ToolTip="gpt-5 (default), gpt-4o-2024-08-06, gpt-4o-mini…" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                  <TextBlock Text="API key OpenAI:" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="0,0,6,0" />
                  <PasswordBox x:Name="OpenAiApiKeyBox" Width="280"
                               VerticalAlignment="Center" VerticalContentAlignment="Center"
                               Foreground="{DynamicResource Text}"
                               PasswordChanged="OnOpenAiApiKeyChanged"
                               ToolTip="Da platform.openai.com. Salvata cifrata DPAPI sul tuo PC." />
                  <TextBlock Text="✓ configurata" Style="{StaticResource Muted}" FontSize="11"
                             VerticalAlignment="Center" Margin="10,0,0,0"
                             Visibility="{Binding HasOpenAiApiKey, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <TextBlock Style="{StaticResource Muted}" Margin="2,12,0,0" TextWrapping="Wrap"
                     Text="{Binding Status}" />

          <Border Style="{StaticResource Card}" Margin="0,12,0,0"
                  Visibility="{Binding HasAnswer, Converter={StaticResource BoolToVis}}">
            <TextBlock Style="{StaticResource Body}" Text="{Binding Answer}" TextWrapping="Wrap" />
          </Border>

          <ItemsControl ItemsSource="{Binding Suggestions}" Margin="0,4,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                  <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                      <Button Style="{StaticResource GhostButton}" Content="Come fare"
                              Command="{Binding HowToCommand}" />
                      <Button x:Name="cpBiosBtn" Style="{StaticResource GhostButton}" Content="Istruzioni BIOS"
                              Margin="6,0,0,0" Command="{Binding Toggle.ToggleBiosGuideCommand}"
                              Visibility="{Binding Toggle.HasBiosGuide, FallbackValue=Collapsed, Converter={StaticResource BoolToVis}}" />
                      <Popup IsOpen="{Binding Toggle.IsBiosPopupOpen, Mode=TwoWay}" StaysOpen="False"
                             PlacementTarget="{Binding ElementName=cpBiosBtn}" Placement="Bottom" AllowsTransparency="True">
                        <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Line}"
                                BorderThickness="1" CornerRadius="12" Padding="16" Margin="8">
                          <StackPanel Width="236">
                            <TextBlock Style="{StaticResource H2}" Text="Istruzioni BIOS sul telefono" />
                            <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,10"
                                       Text="Inquadra il QR: si apre la guida passo-passo per la TUA scheda madre (IT/EN). Funziona anche col PC nel BIOS." />
                            <Border Background="White" CornerRadius="8" Padding="8" HorizontalAlignment="Center">
                              <Image Source="{Binding Toggle.QrImage}" Width="190" Height="190" />
                            </Border>
                            <Button Style="{StaticResource GhostButton}" Content="Apri il link nel browser" Margin="0,10,0,0"
                                    Command="{Binding Toggle.OpenBiosGuideCommand}" />
                          </StackPanel>
                        </Border>
                      </Popup>
                      <ToggleButton Style="{StaticResource Switch}" Margin="10,0,2,0"
                                    IsChecked="{Binding Toggle.IsOn, Mode=TwoWay}"
                                    IsEnabled="{Binding Toggle.ToggleEnabled, FallbackValue=False}"
                                    ToolTip="{Binding Toggle.StatusLine}"
                                    Visibility="{Binding CanApply, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Style="{StaticResource H2}" Text="{Binding Name}" />
                      <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap"
                                 Text="{Binding Impact}" Margin="0,2,0,0" />
                      <TextBlock Style="{StaticResource Muted}" FontSize="11"
                                 Text="{Binding State}" Margin="0,2,0,0" />
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:SettingsViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Style="{StaticResource H1}" Text="Impostazioni" />
          <Border Style="{StaticResource Card}" Margin="0,16,0,8">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="Tema" />
              <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,10"
                         Text="10 sistemi completi: palette, tipografia e modalità chiara/scura cambiano insieme. I colori semantici (ok/avviso/pericolo) restano sempre leggibili." />
              <ListBox ItemsSource="{Binding Themes}" SelectedValuePath="Name"
                       SelectedValue="{Binding SelectedTheme}"
                       Background="Transparent" BorderThickness="0"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="0,0,12,12" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                          <Border x:Name="cardWrap" CornerRadius="14" BorderThickness="2"
                                  BorderBrush="Transparent" RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter />
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="cardWrap" Property="RenderTransform">
                                <Setter.Value>
                                  <TranslateTransform Y="-3" />
                                </Setter.Value>
                              </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                              <Setter TargetName="cardWrap" Property="BorderBrush" Value="{DynamicResource Accent}" />
                              <Setter TargetName="cardWrap" Property="Effect">
                                <Setter.Value>
                                  <DropShadowEffect Color="{DynamicResource C.Accent}" BlurRadius="24" ShadowDepth="0" Opacity="0.55" />
                                </Setter.Value>
                              </Setter>
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Width="172" CornerRadius="12" Background="{Binding Surface}"
                            BorderBrush="{Binding Line}" BorderThickness="1">
                      <StackPanel>
                        <!-- mini-mockup: the theme's own bg + surfaces + accent -->
                        <Border Background="{Binding Bg}" Padding="12,11" Height="96" CornerRadius="11,11,0,0">
                          <StackPanel>
                            <StackPanel Orientation="Horizontal">
                              <Ellipse Width="10" Height="10" Fill="{Binding Accent}" VerticalAlignment="Center" />
                              <Border Height="6" Width="64" CornerRadius="3" Background="{Binding Text}"
                                      Opacity="0.55" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <Border Height="11" CornerRadius="4" Background="{Binding Surface}" Margin="0,9,0,0" />
                            <Border Height="11" CornerRadius="4" Background="{Binding Surface2}" Margin="0,5,0,0" />
                            <Border Height="15" Width="58" CornerRadius="5" Background="{Binding Accent}"
                                    Margin="0,9,0,0" HorizontalAlignment="Left" />
                          </StackPanel>
                        </Border>
                        <!-- meta: each card previews its own text colors -->
                        <Border Background="{Binding Surface}" Padding="11,9" CornerRadius="0,0,11,11">
                          <StackPanel>
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                         Foreground="{Binding Text}" VerticalAlignment="Center" />
                              <Border Background="{Binding Surface2}" CornerRadius="4" Padding="6,1"
                                      Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ModeLabel}" FontSize="10"
                                           Foreground="{Binding Text}" Opacity="0.7" />
                              </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Mood}" Foreground="{Binding Text}" Opacity="0.6"
                                       FontSize="11" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding FontLabel}" FontFamily="{DynamicResource MonoFont}"
                                       Foreground="{Binding Text}" Opacity="0.5" FontSize="10.5" Margin="0,2,0,0" />
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </Border>
          <Border Style="{StaticResource Card}" Margin="0,0,0,8">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="Misurazione" />
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Style="{StaticResource Body}" Text="Run di benchmark predefiniti" Width="240"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding DefaultBenchmarkRuns, UpdateSourceTrigger=LostFocus}" Width="64" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Style="{StaticResource Body}" Text="Soglia noise-gate (%)" Width="240"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding NoiseGateThresholdPercent, UpdateSourceTrigger=LostFocus}" Width="64" />
              </StackPanel>
              <CheckBox Content="Liste compatte" IsChecked="{Binding CompactLists}" Margin="0,12,0,0"
                        Foreground="{DynamicResource Text}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="Aggiornamenti" />
              <TextBlock Style="{StaticResource Body}" Text="{Binding UpdateStatus}" Margin="0,8,0,0"
                         TextWrapping="Wrap" />
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Style="{StaticResource GhostButton}" Content="Controlla aggiornamenti"
                        Command="{Binding CheckUpdatesCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Content="Scarica" Margin="10,0,0,0"
                        Command="{Binding OpenDownloadCommand}"
                        Visibility="{Binding HasUpdateDownload, Converter={StaticResource BoolToVis}}" />
              </StackPanel>
              <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                         Text="Consent-first: Verdict controlla soltanto e ti dice dove scaricare. Non scarica né installa mai da solo." />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="Community e prove" />
              <TextBlock Style="{StaticResource Body}" Text="{Binding EvidenceSummary}" Margin="0,8,0,0"
                         TextWrapping="Wrap" />
              <TextBlock Style="{StaticResource Muted}" FontSize="11" Text="{Binding CommunityStatus}"
                         Margin="0,8,0,0" TextWrapping="Wrap" />
              <CheckBox Margin="0,12,0,0" IsChecked="{Binding CommunityShareEnabled, Mode=TwoWay}"
                        Content="Condividi i miei esiti anonimi con la community Verdict"
                        Foreground="{DynamicResource Text}" />
              <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="22,4,0,0" TextWrapping="Wrap"
                         Text="Spedito: rig_signature (hash anonimo), tier, tweak id, esito, delta misurato. Niente IP, niente nome, niente modello esatto. Vedi docs/V7_REMOTE_BACKEND_DESIGN.md sez. 7." />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="Informazioni" />
              <TextBlock Style="{StaticResource Body}" Text="{Binding About}" Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <DockPanel>
      <!-- Terminal line: identity (the CLI underneath) and guarantee (0 writes). -->
      <Border DockPanel.Dock="Bottom" Background="{DynamicResource Ink}"
              BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="16,6">
        <TextBlock Style="{StaticResource Mono}" Foreground="{DynamicResource TextMuted}"
                   Text="{Binding TerminalLine}" />
      </Border>

      <!-- Sidebar -->
      <Border DockPanel.Dock="Left" Width="208" Background="{DynamicResource Ink}"
              BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="20,24,20,16">
            <TextBlock Style="{StaticResource H2}" FontSize="20" Foreground="{DynamicResource Accent}"
                       Text="Verdict" />
            <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap"
                       Text="L'unico ottimizzatore che ti dice quando smettere di ottimizzare." />
          </StackPanel>
          <TextBlock DockPanel.Dock="Bottom" Style="{StaticResource Muted}" FontSize="10.5" Opacity="0.6"
                     Margin="20,0,20,16" Text="{x:Static local:AppInfo.VersionLabel}" />
          <StackPanel>
            <!-- 2ª passata Design: Path icons stroke-line accanto a ogni voce (elimina il "tell
                 amatoriale" delle emoji/glyph nel brief sez. 11). Ogni icona e' 16x16 approssimata
                 al concept della pagina (gauge/scan/chart/etc). -->
            <RadioButton x:Name="NavVerdict" Style="{StaticResource NavButton}" IsChecked="True" Checked="OnNavVerdict">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 2 8 A 6 6 0 0 1 14 8 M 8 8 L 11 5" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Verdict" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavScan" Style="{StaticResource NavButton}" Checked="OnNavScan">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 2 4 L 14 4 M 2 8 L 14 8 M 2 12 L 14 12" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Scansione" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavMeasure" Style="{StaticResource NavButton}" Checked="OnNavMeasure">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
                      Data="M 3 13 L 3 8 M 7 13 L 7 5 M 11 13 L 11 3" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Misura" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavDiagnostics" Style="{StaticResource NavButton}" Checked="OnNavDiagnostics">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 8 2 L 8 10 M 4 6 L 12 6 M 4 10 L 12 10 M 4 14 L 12 14" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Diagnostica" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavKb" Style="{StaticResource NavButton}" Checked="OnNavKb">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 3 3 L 3 13 L 13 13 L 13 3 M 8 3 L 8 13" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Knowledge Base" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavReport" Style="{StaticResource NavButton}" Checked="OnNavReport">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 4 2 L 12 2 L 12 14 L 4 14 Z M 6 6 L 10 6 M 6 9 L 10 9 M 6 12 L 8 12" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Report" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavChanges" Style="{StaticResource NavButton}" Checked="OnNavChanges">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 8 3 A 5 5 0 1 1 3 8 M 3 8 L 3 4 M 3 4 L 6 4 M 8 5 L 8 8 L 10 10" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Modifiche" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavProfiles" Style="{StaticResource NavButton}" Checked="OnNavProfiles">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 8 3 A 2.5 2.5 0 1 1 7.99 3 M 3 14 A 5 4 0 0 1 13 14" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Profili" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavLab" Style="{StaticResource NavButton}" Checked="OnNavLab">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 6 2 L 6 6 L 3 12 L 13 12 L 10 6 L 10 2 M 5 2 L 11 2" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Lab" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavCoPilot" Style="{StaticResource NavButton}" Checked="OnNavCoPilot">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 3 5 L 13 5 L 13 10 L 8 10 L 6 12 L 6 10 L 3 10 Z" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Co-pilota" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
            <RadioButton x:Name="NavSettings" Style="{StaticResource NavButton}" Checked="OnNavSettings">
              <StackPanel Orientation="Horizontal">
                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"
                      Data="M 8 5 A 3 3 0 1 1 7.99 5 M 8 1 L 8 3 M 8 13 L 8 15 M 1 8 L 3 8 M 13 8 L 15 8 M 3 3 L 4.5 4.5 M 11.5 11.5 L 13 13 M 3 13 L 4.5 11.5 M 11.5 4.5 L 13 3" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Impostazioni" VerticalAlignment="Center" />
              </StackPanel>
            </RadioButton>
          </StackPanel>
        </DockPanel>
      </Border>

      <ContentControl Content="{Binding CurrentPage}" />
    </DockPanel>

    <!-- First-run welcome (EDGE_CASES §2): nothing runs until consent. -->
    <Grid Background="#E00F0F14"
          Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}">
      <Border Style="{StaticResource Card}" MaxWidth="520" VerticalAlignment="Center"
              HorizontalAlignment="Center" Padding="32">
        <StackPanel>
          <TextBlock Style="{StaticResource H1}" Foreground="{DynamicResource Accent}" Text="Verdict" />
          <TextBlock Style="{StaticResource Body}" Margin="0,12,0,0"
                     Text="Verdict misura, diagnostica e consiglia. Non modifica nulla finché non sei tu a decidere." />
          <TextBlock Style="{StaticResource Muted}" Margin="0,8,0,0"
                     Text="L'unico ottimizzatore che ti dice quando smettere di ottimizzare." />
          <TextBlock Style="{StaticResource Muted}" Margin="0,16,0,0" Text="Le regole di Verdict:" />
          <TextBlock Style="{StaticResource Body}" Margin="0,4,0,0"
                     Text="· Scrive SOLO ciò che ti mostra, dopo la tua conferma&#x0a;· Ogni modifica è reversibile — l'annulli quando vuoi&#x0a;· Niente FPS finti: ti dice anche quando un tweak NON serve" />
          <Button Style="{StaticResource PrimaryButton}" Content="Scansiona il PC" Margin="0,24,0,0"
                  HorizontalAlignment="Left" Command="{Binding StartFirstScanCommand}" />
          <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,8,0,0"
                     Text="La scansione è in sola lettura e non serve amministratore." />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Apply-all batch dialog: one consent, every recommended+applicable tweak, each still journaled. -->
    <Grid Background="#E00F0F14"
          Visibility="{Binding ApplyAll.IsOpen, Converter={StaticResource BoolToVis}}">
      <Border Style="{StaticResource Card}" MaxWidth="680" MaxHeight="640" VerticalAlignment="Center"
              HorizontalAlignment="Center" Padding="28" DataContext="{Binding ApplyAll}">
        <StackPanel>
          <TextBlock Style="{StaticResource H2}" Text="{Binding Title}" />
          <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0"
                     Text="Anteprima — ogni modifica qui sotto, su tutti i tweak consigliati. Ognuna viene scritta, riletta per verifica e tracciata singolarmente così puoi annullarla dalla pagina Modifiche. Non succede niente finché non confermi." />

          <Border Background="{DynamicResource Surface2}" CornerRadius="6" Padding="14" Margin="0,12,0,0"
                  Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
              <TextBlock Style="{StaticResource Mono}" FontSize="12" Text="{Binding PlanText}" TextWrapping="Wrap" />
            </ScrollViewer>
          </Border>

          <TextBlock Style="{StaticResource Muted}" Text="{Binding Status}" Margin="0,12,0,0" TextWrapping="Wrap" />

          <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <Button Style="{StaticResource PrimaryButton}" Content="Applica tutti ora"
                    Command="{Binding ConfirmCommand}"
                    Visibility="{Binding ShowApplyButton, Converter={StaticResource BoolToVis}}" />
            <Button Style="{StaticResource PrimaryButton}" Content="Riavvia come amministratore"
                    Command="{Binding RelaunchAsAdminCommand}" Margin="8,0,0,0"
                    Visibility="{Binding AdminBlocked, Converter={StaticResource BoolToVis}}" />
            <Button Style="{StaticResource GhostButton}" Content="Chiudi"
                    Command="{Binding CancelCommand}" Margin="8,0,0,0" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Toast: transient feedback (Apply/Verify/Revert), bottom-right, auto-dismiss ~2.8s. -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,24,52"
            Background="{DynamicResource Surface2}" CornerRadius="10" Padding="14,11"
            BorderThickness="1.5" RenderTransformOrigin="0.5,1"
            BorderBrush="{Binding ToastColor, Converter={StaticResource TokenBrush}}"
            Visibility="{Binding ToastVisible, Converter={StaticResource BoolToVis}}">
      <Border.RenderTransform>
        <TranslateTransform Y="0" />
      </Border.RenderTransform>
      <Border.Effect>
        <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.5" Color="#000000" />
      </Border.Effect>
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <!-- toastIn: slide up + fade in (~0.28s) when a toast appears -->
            <DataTrigger Binding="{Binding ToastVisible}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="18" To="0" Duration="0:0:0.28" />
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.28" />
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel Orientation="Horizontal">
        <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                 Fill="{Binding ToastColor, Converter={StaticResource TokenBrush}}" />
        <TextBlock Text="{Binding ToastMessage}" Margin="10,0,0,0" VerticalAlignment="Center"
                   Foreground="{DynamicResource Text}" FontSize="13" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
