<Window x:Class="WPEP.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WPEP.App"
        Title="Verdict" Width="1180" Height="760" MinWidth="980" MinHeight="640"
        Background="{DynamicResource Bg}"
        FontFamily="{StaticResource UiFont}">

  <Window.Resources>
    <local:TokenBrushConverter x:Key="TokenBrush" />
    <local:BoolToVisibilityConverter x:Key="BoolToVis" />
    <local:BoolToVisibilityConverter x:Key="BoolToVisInverted" Invert="True" />
    <local:NullToVisibilityConverter x:Key="NullToVis" />

    <!-- ============ VERDICT ============ -->
    <DataTemplate DataType="{x:Type local:VerdictViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">
          <DockPanel>
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}"
                    Content="Rescan" Command="{Binding RescanCommand}" VerticalAlignment="Top" />
            <StackPanel>
              <TextBlock Style="{StaticResource H1}" Text="{Binding Header}" />
              <TextBlock Style="{StaticResource Muted}" Text="{Binding SubHeader}" Margin="0,4,0,0" />
            </StackPanel>
          </DockPanel>

          <UniformGrid Columns="3" Margin="0,24,0,0">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Style="{StaticResource Mono}" FontSize="26"
                           Foreground="{DynamicResource Ok}" Text="{Binding WorthDoing}" />
                <TextBlock Style="{StaticResource H2}" Text="Worth doing" Margin="0,8,0,0" />
                <TextBlock Style="{StaticResource Muted}" Text="Free improvements with real evidence" />
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
              <StackPanel>
                <TextBlock Style="{StaticResource Mono}" FontSize="26"
                           Foreground="{DynamicResource OkDim}" Text="{Binding AlreadyOptimal}" />
                <TextBlock Style="{StaticResource H2}" Text="Already optimal" Margin="0,8,0,0" />
                <TextBlock Style="{StaticResource Muted}" Text="Nothing to do here. That's good news." />
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
              <StackPanel>
                <TextBlock Style="{StaticResource Mono}" FontSize="26"
                           Foreground="{DynamicResource Neutral}" Text="{Binding PlaceboAvoided}" />
                <TextBlock Style="{StaticResource H2}" Text="Placebo avoided" Margin="0,8,0,0" />
                <TextBlock Style="{StaticResource Muted}" Text="Popular tweaks that don't actually work" />
              </StackPanel>
            </Border>
          </UniformGrid>

          <ItemsControl ItemsSource="{Binding Groups}" Margin="0,24,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,0,0,20">
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding BadgeColorKey, Converter={StaticResource TokenBrush}}" />
                    <TextBlock Style="{StaticResource H2}" Text="{Binding Label}" Margin="8,0,8,0" />
                    <TextBlock Style="{StaticResource Mono}" Foreground="{DynamicResource TextMuted}"
                               Text="{Binding Count}" VerticalAlignment="Center" />
                  </StackPanel>
                  <Border Style="{StaticResource Card}" Padding="8">
                    <ItemsControl ItemsSource="{Binding Items}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="8,6">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="300" />
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                              <TextBlock Style="{StaticResource Body}" Text="{Binding Name}" />
                              <TextBlock Style="{StaticResource Mono}" FontSize="11"
                                         Foreground="{DynamicResource TextMuted}" Text="{Binding Id}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Style="{StaticResource Muted}"
                                       Text="{Binding StateNote}" VerticalAlignment="Center" Margin="16,0,0,0" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                              <Button Style="{StaticResource GhostButton}" Content="How to"
                                      Padding="10,4" FontSize="12" Margin="8,0,0,0"
                                      Command="{Binding HowToCommand}" />
                              <Button Style="{StaticResource PrimaryButton}" Content="Apply"
                                      Padding="12,4" FontSize="12" Margin="6,0,0,0"
                                      Command="{Binding ApplyCommand}"
                                      Visibility="{Binding CanApply, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Border>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ============ MEASURE (wizard) ============ -->
    <DataTemplate DataType="{x:Type local:MeasureWizardViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="820" HorizontalAlignment="Left">
          <TextBlock Style="{StaticResource H1}" Text="Measure" />
          <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,16"
                     Text="Baseline → ONE change → post → verdict. The method is the product." />

          <!-- Blockers (F1/F2) -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                  Visibility="{Binding CanMeasure, Converter={StaticResource BoolToVisInverted}}">
            <StackPanel>
              <TextBlock Style="{StaticResource Body}" Text="{Binding BlockerText}" />
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Style="{StaticResource PrimaryButton}" Content="Relaunch as administrator"
                        Command="{Binding RelaunchAsAdminCommand}"
                        Visibility="{Binding IsElevated, Converter={StaticResource BoolToVisInverted}}" />
                <Button Style="{StaticResource PrimaryButton}" Content="Download PresentMon (10 MB, verified)"
                        Command="{Binding InstallPresentMonCommand}"
                        Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}" />
              </StackPanel>
              <TextBlock Style="{StaticResource Muted}" Text="{Binding Status}" Margin="0,8,0,0" />
            </StackPanel>
          </Border>

          <!-- Step 1: pick -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                  Visibility="{Binding IsStepPick, Converter={StaticResource BoolToVis}}">
            <StackPanel IsEnabled="{Binding CanMeasure}">
              <TextBlock Style="{StaticResource H2}" Text="1 · Pick your game &amp; scenario" />
              <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,12"
                         Text="You CAN measure live matches — but they're usually too noisy for a verdict. A repeatable scenario means the same in-game situation each run (same Creative map and route, same benchmark), not replaying an old capture. We'll measure either way and tell you honestly what the data can support." />
              <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Refresh"
                        Command="{Binding RefreshProcessesCommand}" Margin="8,0,0,0" />
                <ComboBox ItemsSource="{Binding Processes}" SelectedItem="{Binding Target}"
                          DisplayMemberPath="Display" />
              </DockPanel>
              <TextBlock Style="{StaticResource H2}" FontSize="13" Text="Scenario protocol" Margin="0,16,0,4" />
              <ComboBox ItemsSource="{Binding Scenarios}" SelectedItem="{Binding Scenario}"
                        DisplayMemberPath="Name" />
              <Border Background="{DynamicResource Surface2}" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                <TextBlock Style="{StaticResource Body}" FontSize="12.5"
                           Text="{Binding Scenario.Instructions}" TextWrapping="Wrap" />
              </Border>
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource Body}" Text="Seconds per run" Width="160" VerticalAlignment="Center" />
                <TextBox Text="{Binding Seconds, UpdateSourceTrigger=LostFocus}" Width="64" />
                <TextBlock Style="{StaticResource Muted}" Margin="16,0,0,0" VerticalAlignment="Center">
                  <Run Text="Runs per group: " /><Run Text="{Binding Runs, Mode=OneWay}" />
                  <Run Text=" (Settings)" />
                </TextBlock>
              </StackPanel>
              <Button Style="{StaticResource PrimaryButton}" Content="Start baseline"
                      Command="{Binding StartBaselineCommand}" Margin="0,16,0,0" HorizontalAlignment="Left" />
            </StackPanel>
          </Border>

          <!-- Step 3: apply ONE change -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                  Visibility="{Binding IsStepApplyChange, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="3 · Apply ONE change" />
              <TextBlock Style="{StaticResource Body}" Margin="0,8,0,0"
                         Text="One change at a time, or you won't know what did what. Apply it now (by hand — WPEP never writes), then come back." />
              <Button Style="{StaticResource PrimaryButton}" Content="I applied ONE change — run post"
                      Command="{Binding StartPostCommand}" Margin="0,16,0,0" HorizontalAlignment="Left" />
            </StackPanel>
          </Border>

          <!-- Verdict -->
          <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                  Visibility="{Binding IsStepVerdict, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="5 · Verdict" />
              <TextBlock Style="{StaticResource Mono}" Margin="0,12,0,0" TextWrapping="Wrap"
                         Text="{Binding VerdictText}" />
              <Button Style="{StaticResource GhostButton}" Content="Start over"
                      Command="{Binding RestartCommand}" Margin="0,16,0,0" HorizontalAlignment="Left" />
            </StackPanel>
          </Border>

          <!-- Run log -->
          <Border Style="{StaticResource Card}" Background="{DynamicResource Surface2}"
                  Visibility="{Binding RunLog.Count, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding RunLog}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Style="{StaticResource Mono}" Text="{Binding}" TextWrapping="Wrap" Margin="0,1" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ============ DIAGNOSTICS ============ -->
    <DataTemplate DataType="{x:Type local:DiagnosticsViewModel}">
      <StackPanel Margin="32,24">
        <TextBlock Style="{StaticResource H1}" Text="Diagnostics" />
        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,16"
                   Text="Kernel DPC/ISR latency per driver — finds the actual stutter culprit, or tells you there is none." />
        <TextBlock Style="{StaticResource Body}" Text="{Binding Status}" Margin="0,0,0,12" />
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryButton}" Content="Capture"
                  Command="{Binding CaptureCommand}"
                  Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}" />
          <TextBox Text="{Binding Seconds, UpdateSourceTrigger=LostFocus}" Width="56"
                   Margin="8,0,0,0" VerticalAlignment="Center"
                   Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}" />
          <TextBlock Style="{StaticResource Muted}" Text="seconds" Margin="6,0,0,0" VerticalAlignment="Center"
                     Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}" />
          <Button Style="{StaticResource PrimaryButton}" Content="Relaunch as administrator"
                  Command="{Binding RelaunchAsAdminCommand}"
                  Visibility="{Binding IsElevated, Converter={StaticResource BoolToVisInverted}}" />
        </StackPanel>
        <TextBlock Style="{StaticResource H2}" Foreground="{DynamicResource Accent}"
                   Text="{Binding VerdictLine}" Margin="0,16,0,8" TextWrapping="Wrap" />
        <Border Style="{StaticResource Card}" Padding="8"
                Visibility="{Binding Rows.Count, Converter={StaticResource BoolToVis}}">
          <ItemsControl ItemsSource="{Binding Rows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="8,3">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Style="{StaticResource Mono}" Text="{Binding Driver}" />
                  <TextBlock Grid.Column="1" Style="{StaticResource Mono}" Text="{Binding Events}"
                             Foreground="{DynamicResource TextMuted}" />
                  <TextBlock Grid.Column="2" Style="{StaticResource Mono}" Text="{Binding MaxUs}" />
                  <TextBlock Grid.Column="3" Style="{StaticResource Mono}" Text="{Binding AvgUs}"
                             Foreground="{DynamicResource TextMuted}" />
                  <TextBlock Grid.Column="4" Style="{StaticResource Mono}" Text="{Binding Spikes}"
                             Foreground="{DynamicResource TextMuted}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>
      </StackPanel>
    </DataTemplate>

    <!-- ============ KNOWLEDGE BASE ============ -->
    <DataTemplate DataType="{x:Type local:KbViewModel}">
      <Grid Margin="32,24">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
          <TextBlock Style="{StaticResource H1}" Text="Knowledge Base" VerticalAlignment="Center" />
          <ComboBox ItemsSource="{Binding Filters}" SelectedItem="{Binding Filter}"
                    Margin="24,0,0,0" Width="180" VerticalAlignment="Center" />
          <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                   Width="220" Margin="12,0,0,0" VerticalAlignment="Center"
                   ToolTip="Search name, id or description" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,16,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Style="{StaticResource Card}" Padding="4">
            <ListBox ItemsSource="{Binding Entries}" SelectedItem="{Binding Selected}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <DockPanel Margin="4,4" LastChildFill="True">
                    <Border DockPanel.Dock="Right" Style="{StaticResource Badge}"
                            Background="{Binding Badge.ColorKey, Converter={StaticResource TokenBrush}}">
                      <TextBlock Text="{Binding Badge.Label}" FontSize="11" Foreground="#0F0F14" />
                    </Border>
                    <StackPanel>
                      <TextBlock Style="{StaticResource Body}" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                      <TextBlock Style="{StaticResource Mono}" FontSize="11"
                                 Foreground="{DynamicResource TextMuted}" Text="{Binding Id}" />
                    </StackPanel>
                  </DockPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource Card}" Margin="16,0,0,0"
                  Visibility="{Binding Selected, Converter={StaticResource NullToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel DataContext="{Binding Selected}">
                <TextBlock Style="{StaticResource H2}" Text="{Binding Name}" />
                <TextBlock Style="{StaticResource Mono}" FontSize="11" Margin="0,2,0,12"
                           Foreground="{DynamicResource TextMuted}" Text="{Binding Id}" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding Entry.Description}" />
                <TextBlock Style="{StaticResource H2}" Text="Expected impact" Margin="0,16,0,4" FontSize="13" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding Entry.ExpectedImpact}" />
                <TextBlock Style="{StaticResource H2}" Text="How to (manual)" Margin="0,16,0,4" FontSize="13" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding Entry.ManualSteps}" />
                <TextBlock Style="{StaticResource H2}" Text="Rollback" Margin="0,16,0,4" FontSize="13" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding Entry.Rollback}" />
                <TextBlock Style="{StaticResource H2}" Text="Sources" Margin="0,16,0,4" FontSize="13" />
                <ItemsControl ItemsSource="{Binding Entry.Sources}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Style="{StaticResource Mono}" FontSize="11" Text="{Binding}"
                                 Foreground="{DynamicResource Info}" TextWrapping="Wrap" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>
        <TextBlock Grid.Row="2" Style="{StaticResource Muted}" Text="{Binding Footer}" Margin="0,12,0,0" />
      </Grid>
    </DataTemplate>

    <!-- ============ REPORT ============ -->
    <DataTemplate DataType="{x:Type local:ReportViewModel}">
      <StackPanel Margin="32,24" MaxWidth="720" HorizontalAlignment="Left">
        <TextBlock Style="{StaticResource H1}" Text="Report" />
        <TextBlock Style="{StaticResource Body}" Text="{Binding Status}" Margin="0,12,0,16" />
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryButton}" Content="Generate report"
                  Command="{Binding GenerateCommand}" />
          <Button Style="{StaticResource GhostButton}" Content="Open last report"
                  Command="{Binding OpenCommand}" Margin="12,0,0,0"
                  Visibility="{Binding LastPath, Converter={StaticResource NullToVis}}" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- ============ CHANGES (undo journal) ============ -->
    <DataTemplate DataType="{x:Type local:ChangesViewModel}">
      <StackPanel Margin="32,24" MaxWidth="820" HorizontalAlignment="Left">
        <TextBlock Style="{StaticResource H1}" Text="Changes" />
        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,16"
                   Text="Every change Verdict applied, newest first. Each is journaled and reversible — undo restores the exact previous value." />
        <Border Style="{StaticResource Card}" Padding="20"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
          <TextBlock Style="{StaticResource Muted}"
                     Text="No changes applied yet. Verdict has written nothing to your system." />
        </Border>
        <ItemsControl ItemsSource="{Binding Sessions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="16,12">
                <DockPanel>
                  <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Undo"
                          Command="{Binding DataContext.UndoCommand,
                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}" VerticalAlignment="Center" />
                  <TextBlock Style="{StaticResource Mono}" Text="{Binding Display}"
                             VerticalAlignment="Center" />
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock Style="{StaticResource Muted}" Text="{Binding Status}" Margin="0,8,0,0" />
      </StackPanel>
    </DataTemplate>

    <!-- ============ SETTINGS ============ -->
    <DataTemplate DataType="{x:Type local:SettingsViewModel}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Style="{StaticResource H1}" Text="Settings" />
          <Border Style="{StaticResource Card}" Margin="0,16,0,8">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="Theme" />
              <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,8"
                         Text="Accent only — semantic colors (ok/warn/danger) never change. Meaning is not customizable." />
              <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" Width="200"
                        HorizontalAlignment="Left" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource Card}" Margin="0,0,0,8">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="Measurement" />
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Style="{StaticResource Body}" Text="Default benchmark runs" Width="240"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding DefaultBenchmarkRuns, UpdateSourceTrigger=LostFocus}" Width="64" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Style="{StaticResource Body}" Text="Noise gate threshold (%)" Width="240"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding NoiseGateThresholdPercent, UpdateSourceTrigger=LostFocus}" Width="64" />
              </StackPanel>
              <CheckBox Content="Compact lists" IsChecked="{Binding CompactLists}" Margin="0,12,0,0"
                        Foreground="{DynamicResource Text}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <TextBlock Style="{StaticResource H2}" Text="About" />
              <TextBlock Style="{StaticResource Body}" Text="{Binding About}" Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <DockPanel>
      <!-- Terminal line: identity (the CLI underneath) and guarantee (0 writes). -->
      <Border DockPanel.Dock="Bottom" Background="{DynamicResource Surface}"
              BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="16,6">
        <TextBlock Style="{StaticResource Mono}" Foreground="{DynamicResource TextMuted}"
                   Text="{Binding TerminalLine}" />
      </Border>

      <!-- Sidebar -->
      <Border DockPanel.Dock="Left" Width="208" Background="{DynamicResource Surface}"
              BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="20,24,20,16">
            <TextBlock Style="{StaticResource H2}" FontSize="20" Foreground="{DynamicResource Accent}"
                       Text="Verdict" />
            <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap"
                       Text="The only optimizer that tells you when to stop optimizing." />
          </StackPanel>
          <StackPanel>
            <RadioButton x:Name="NavVerdict" Style="{StaticResource NavButton}" Content="Verdict"
                         IsChecked="True" Checked="OnNavVerdict" />
            <RadioButton x:Name="NavMeasure" Style="{StaticResource NavButton}" Content="Measure"
                         Checked="OnNavMeasure" />
            <RadioButton x:Name="NavDiagnostics" Style="{StaticResource NavButton}" Content="Diagnostics"
                         Checked="OnNavDiagnostics" />
            <RadioButton x:Name="NavKb" Style="{StaticResource NavButton}" Content="Knowledge Base"
                         Checked="OnNavKb" />
            <RadioButton x:Name="NavReport" Style="{StaticResource NavButton}" Content="Report"
                         Checked="OnNavReport" />
            <RadioButton x:Name="NavChanges" Style="{StaticResource NavButton}" Content="Changes"
                         Checked="OnNavChanges" />
            <RadioButton x:Name="NavSettings" Style="{StaticResource NavButton}" Content="Settings"
                         Checked="OnNavSettings" />
          </StackPanel>
        </DockPanel>
      </Border>

      <ContentControl Content="{Binding CurrentPage}" />
    </DockPanel>

    <!-- First-run welcome (EDGE_CASES §2): nothing runs until consent. -->
    <Grid Background="#E00F0F14"
          Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}">
      <Border Style="{StaticResource Card}" MaxWidth="520" VerticalAlignment="Center"
              HorizontalAlignment="Center" Padding="32">
        <StackPanel>
          <TextBlock Style="{StaticResource H1}" Foreground="{DynamicResource Accent}" Text="Verdict" />
          <TextBlock Style="{StaticResource Body}" Margin="0,12,0,0"
                     Text="Verdict measures, diagnoses and recommends. It never modifies your system." />
          <TextBlock Style="{StaticResource Muted}" Margin="0,8,0,0"
                     Text="The only optimizer that tells you when to stop optimizing." />
          <TextBlock Style="{StaticResource Muted}" Margin="0,16,0,0" Text="What WPEP will never do:" />
          <TextBlock Style="{StaticResource Body}" Margin="0,4,0,0"
                     Text="· Write to your system&#x0a;· Claim to measure end-to-end input latency&#x0a;· Show you an improvement that isn't statistically real" />
          <Button Style="{StaticResource PrimaryButton}" Content="Scan my system" Margin="0,24,0,0"
                  HorizontalAlignment="Left" Command="{Binding StartFirstScanCommand}" />
          <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,8,0,0"
                     Text="The scan is read-only and needs no administrator." />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Apply dry-run dialog (EXECUTION_ENGINE_V2 §2): exact before→after, consent first. -->
    <Grid Background="#E00F0F14"
          Visibility="{Binding ApplyDialog.IsOpen, Converter={StaticResource BoolToVis}}">
      <Border Style="{StaticResource Card}" MaxWidth="640" VerticalAlignment="Center"
              HorizontalAlignment="Center" Padding="28" DataContext="{Binding ApplyDialog}">
        <StackPanel>
          <TextBlock Style="{StaticResource H2}" Text="{Binding Title}" />
          <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0"
                     Text="Dry run — exactly what will change. Verdict reads the current value, writes the new one, then re-reads to verify. Nothing happens until you confirm." />

          <Border Background="{DynamicResource Surface2}" CornerRadius="6" Padding="14" Margin="0,12,0,0">
            <TextBlock Style="{StaticResource Mono}" FontSize="12" Text="{Binding PlanText}" TextWrapping="Wrap" />
          </Border>

          <Border Background="#33F87171" CornerRadius="6" Padding="14" Margin="0,12,0,0"
                  Visibility="{Binding IsRisky, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Style="{StaticResource Body}" Foreground="{DynamicResource Danger}"
                         Text="Risk — read before applying:" />
              <TextBlock Style="{StaticResource Body}" Text="{Binding RiskText}" Margin="0,4,0,0" />
            </StackPanel>
          </Border>

          <TextBlock Style="{StaticResource Muted}" Text="{Binding Status}" Margin="0,12,0,0" TextWrapping="Wrap" />

          <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <Button Style="{StaticResource PrimaryButton}" Content="Apply now"
                    Command="{Binding ConfirmCommand}"
                    Visibility="{Binding Applied, Converter={StaticResource BoolToVisInverted}}" />
            <Button Style="{StaticResource PrimaryButton}" Content="Relaunch as administrator"
                    Command="{Binding RelaunchAsAdminCommand}" Margin="0,0,8,0"
                    Visibility="{Binding AdminBlocked, Converter={StaticResource BoolToVis}}" />
            <Button Style="{StaticResource GhostButton}" Content="Close"
                    Command="{Binding CancelCommand}" Margin="8,0,0,0" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
