<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ============ TOKENS (DESIGN_DIRECTION: tutti i colori vivono qui) ============ -->
  <!-- Accent swappa coi preset; i SEMANTICI (Ok/Warn/Danger/badge) non cambiano mai. -->
  <!-- Default = Villain (design handoff). Swapped at runtime by ThemePresets.Apply. -->
  <Color x:Key="C.Bg">#08070C</Color>
  <Color x:Key="C.Surface">#161019</Color>
  <Color x:Key="C.Surface2">#1F1528</Color>
  <Color x:Key="C.Line">#2C1F3C</Color>
  <Color x:Key="C.Accent">#7C3AED</Color>
  <Color x:Key="C.AccentDeep">#3A0A5C</Color>
  <Color x:Key="C.Text">#E6E6EC</Color>
  <Color x:Key="C.TextMuted">#8A8A96</Color>
  <!-- Ink: darkens chrome (sidebar/footer) + bg vignette. Dark themes #000; light themes a warm grey. -->
  <Color x:Key="C.Ink">#000000</Color>
  <Color x:Key="C.Ok">#34D399</Color>
  <Color x:Key="C.OkDim">#1F7A58</Color>
  <Color x:Key="C.Info">#60A5FA</Color>
  <Color x:Key="C.Warn">#FBBF24</Color>
  <Color x:Key="C.Danger">#F87171</Color>
  <Color x:Key="C.Neutral">#6B7280</Color>
  <!-- OnAccent: testo SCURO da mettere SOPRA Accent (badge/highlight). Costante per design:
       i preset di tema assumono Accent come tinta forte/saturata su cui un ink scuro resta leggibile. -->
  <Color x:Key="C.OnAccent">#0F0F14</Color>

  <SolidColorBrush x:Key="Bg" Color="{DynamicResource C.Bg}" />
  <SolidColorBrush x:Key="Surface" Color="{DynamicResource C.Surface}" />
  <SolidColorBrush x:Key="Surface2" Color="{DynamicResource C.Surface2}" />
  <SolidColorBrush x:Key="Line" Color="{DynamicResource C.Line}" />
  <SolidColorBrush x:Key="Accent" Color="{DynamicResource C.Accent}" />
  <SolidColorBrush x:Key="AccentDeep" Color="{DynamicResource C.AccentDeep}" />
  <SolidColorBrush x:Key="Text" Color="{DynamicResource C.Text}" />
  <SolidColorBrush x:Key="TextMuted" Color="{DynamicResource C.TextMuted}" />
  <SolidColorBrush x:Key="Ok" Color="{DynamicResource C.Ok}" />
  <SolidColorBrush x:Key="OkDim" Color="{DynamicResource C.OkDim}" />
  <SolidColorBrush x:Key="Info" Color="{DynamicResource C.Info}" />
  <SolidColorBrush x:Key="Warn" Color="{DynamicResource C.Warn}" />
  <SolidColorBrush x:Key="Danger" Color="{DynamicResource C.Danger}" />
  <SolidColorBrush x:Key="Neutral" Color="{DynamicResource C.Neutral}" />
  <SolidColorBrush x:Key="Ink" Color="{DynamicResource C.Ink}" />
  <SolidColorBrush x:Key="OnAccent" Color="{DynamicResource C.OnAccent}" />

  <FontFamily x:Key="UiFont">Segoe UI Variable Display, Segoe UI</FontFamily>
  <FontFamily x:Key="MonoFont">Cascadia Code, Cascadia Mono, Consolas</FontFamily>

  <!-- ============ TYPE SCALE (11/12.5/14/16/20/26) ============ -->
  <Style x:Key="H1" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Text}" />
  </Style>
  <Style x:Key="H2" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Text}" />
  </Style>
  <Style x:Key="Body" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource Text}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style x:Key="Muted" TargetType="TextBlock" BasedOn="{StaticResource Body}">
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="FontSize" Value="12.5" />
  </Style>
  <Style x:Key="Mono" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{DynamicResource Text}" />
  </Style>

  <!-- ============ CONTROLS ============ -->
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Line}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <!-- PrimaryButton (2ª passata Design spike 2026-07-01): drop shadow, subtle inner glow su hover,
       scale-in press invece di opacity. Compat: dimensioni/padding invariati. -->
  <Style x:Key="PrimaryButton" TargetType="Button">
    <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="Background" Value="{DynamicResource Accent}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1" />
            </Grid.RenderTransform>
            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                    Padding="{TemplateBinding Padding}" BorderThickness="0">
              <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2"
                                  Direction="270" Opacity="0.25" />
              </Border.Effect>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Effect">
                <Setter.Value>
                  <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3"
                                    Direction="270" Opacity="0.35" />
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX"
                                     To="0.97" Duration="0:0:0.08" />
                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY"
                                     To="0.97" Duration="0:0:0.08" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX"
                                     To="1" Duration="0:0:0.10" />
                    <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY"
                                     To="1" Duration="0:0:0.10" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Text}" />
              <Setter TargetName="bd" Property="BorderThickness" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.4" />
              <Setter TargetName="bd" Property="Effect" Value="{x:Null}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
    <Setter Property="Background" Value="{DynamicResource Surface2}" />
    <Setter Property="Foreground" Value="{DynamicResource Text}" />
  </Style>

  <Style x:Key="NavButton" TargetType="RadioButton">
    <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="bd" CornerRadius="6" Padding="12,8" Margin="8,2" Background="Transparent">
            <ContentPresenter VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource Surface2}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource Surface2}" />
              <Setter Property="Foreground" Value="{DynamicResource Text}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
              <Setter TargetName="bd" Property="BorderThickness" Value="1" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Badge" TargetType="Border">
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ON/OFF pill switch (V6.5 + spike premium 2026-07-01, 2ª passata Design).
       Refinement estetico: inner shadow su track OFF, glow accento su track ON, drop shadow sul knob,
       transizione smooth 150ms del knob. Le dimensioni 46×26 non cambiano — compat pattern esistente. -->
  <Style x:Key="Switch" TargetType="ToggleButton">
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Width" Value="46" />
    <Setter Property="Height" Value="26" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Grid>
            <!-- Glow accento sotto il track quando ON (BlurEffect). Nascosto in OFF. -->
            <Border x:Name="glow" CornerRadius="13" Background="{DynamicResource Accent}" Opacity="0">
              <Border.Effect>
                <BlurEffect Radius="12" />
              </Border.Effect>
            </Border>
            <Border x:Name="track" CornerRadius="13" BorderThickness="1"
                    BorderBrush="{DynamicResource Line}"
                    Background="{DynamicResource Line}" />
            <Ellipse x:Name="knob" Width="20" Height="20" Fill="{DynamicResource TextMuted}"
                     HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0"
                     RenderTransformOrigin="0.5,0.5">
              <Ellipse.RenderTransform>
                <TranslateTransform x:Name="knobShift" X="0" />
              </Ellipse.RenderTransform>
              <Ellipse.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Direction="270"
                                  Opacity="0.35" Color="Black" />
              </Ellipse.Effect>
            </Ellipse>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="track" Property="Background" Value="{DynamicResource Accent}" />
              <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource AccentDeep}" />
              <Setter TargetName="knob" Property="Fill" Value="White" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="knobShift"
                                     Storyboard.TargetProperty="X"
                                     To="20" Duration="0:0:0.15">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="glow"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0.55" Duration="0:0:0.20" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="knobShift"
                                     Storyboard.TargetProperty="X"
                                     To="0" Duration="0:0:0.15">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="glow"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.15" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource TextMuted}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ToolTip">
    <Setter Property="Background" Value="{DynamicResource Surface2}" />
    <Setter Property="Foreground" Value="{DynamicResource Text}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Line}" />
  </Style>
</ResourceDictionary>
